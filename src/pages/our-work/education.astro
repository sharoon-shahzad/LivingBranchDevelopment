---
import Layout from "../../layouts/Layout.astro";
import heroImg from "../../images/programmes/education/living_branch_school/WhatsApp Image 2026-02-02 at 2.08.54 PM.jpeg";
import focusImg from "../../images/programmes/education/oratio_music_school/WhatsApp Image 2026-01-20 at 2.21.29 PM.jpeg";
import bento1 from "../../images/programmes/education/living_branch_school/WhatsApp Image 2026-02-02 at 2.08.51 PM.jpeg";
import bento2 from "../../images/programmes/education/sunday_school_gift_boxes/WhatsApp Image 2026-01-29 at 11.59.27 AM.jpeg";
import bento3 from "../../images/programmes/education/oratio_music_school/WhatsApp Image 2026-01-20 at 2.21.26 PM.jpeg";
import bento4 from "../../images/programmes/education/sunday_school_gift_boxes/WhatsApp Image 2026-01-29 at 11.59.29 AM (1).jpeg";
import bento5 from "../../images/programmes/education/living_branch_school/WhatsApp Image 2026-02-02 at 2.08.52 PM.jpeg";
import bento6 from "../../images/programmes/education/oratio_music_school/WhatsApp Image 2026-01-20 at 2.21.27 PM (1).jpeg";

const stats = [
  {
    value: "26M+",
    label: "school-age children out of school in Pakistan",
    response: "LBD creates bridge classes and community learning hubs so out-of-school children can re-enter education.",
    accent: "var(--brand-cyan)"
  },
  {
    value: "75%",
    label: "children in learning poverty (cannot read by age 10)",
    response: "LBD runs after-school tutoring, reading circles, and homework clubs to strengthen foundational skills.",
    accent: "var(--brand-orange)"
  },
  {
    value: "60%",
    label: "students who never reach higher secondary",
    response: "Through mentoring, scholarships, and family follow-up, LBD helps learners stay in school longer.",
    accent: "var(--brand-pink)"
  }
];

const focusAreas = [
  {
    title: "Learning access",
    description: "Bridge classes, school kits, and after-school tutoring to keep children enrolled."
  },
  {
    title: "Nutrition support",
    description: "Healthy meals and wellness check-ins that improve concentration in class."
  },
  {
    title: "Family engagement",
    description: "Work with caregivers to build routines and reduce dropout risks."
  }
];

const journey = [
  {
    title: "Identify gaps",
    text: "Community leaders map out-of-school children and learning barriers."
  },
  {
    title: "Run learning hubs",
    text: "Local educators deliver daily sessions and track attendance."
  },
  {
    title: "Sustain outcomes",
    text: "Families receive ongoing support so children stay in school."
  }
];

const initiatives = [
  {
    title: "Living Branch School",
    description:
      "Community school classrooms where children who were previously out of school receive consistent teaching, supplies, and encouragement.",
    image: bento1,
    tag: "Bridge to school"
  },
  {
    title: "Oratio Music School",
    description:
      "Creative learning through music and the arts that builds confidence, discipline, and joy in learning for vulnerable children.",
    image: bento6,
    tag: "Learning through creativity"
  },
  {
    title: "Sunday School & Gift Boxes",
    description:
      "Weekend learning spaces and gift boxes with storybooks and resources that keep children connected to reading and faith.",
    image: bento4,
    tag: "Weekend learning"
  }
];
---

<Layout
  title="Education | Living Branch Development"
  description="Living Branch Development education programmes support learning access, nutrition, and family engagement."
>
  <section class="education-hero">
    <div class="container-page grid gap-10 py-16 md:grid-cols-[1.1fr_0.9fr] md:items-center">
      <div>
        <p
          class="inline-flex items-center gap-2 rounded-full bg-white/75 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[color-mix(in_srgb,var(--brand-navy)_80%,black)] shadow-sm ring-1 ring-black/5"
        >
          Programme focus
        </p>
        <h1 class="mt-4 font-heading text-4xl font-semibold tracking-tight text-[var(--fg)] sm:text-5xl">
          Education that keeps children learning and thriving.
        </h1>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-[var(--muted)] sm:text-lg">
          We create safe learning pathways through tutoring, nutrition support, and family engagement so children
          can stay in school and build confidence.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="/donate"
            class="inline-flex items-center justify-center rounded-full bg-[var(--brand-cyan)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[color-mix(in_srgb,var(--brand-cyan)_88%,black)]"
          >
            Support education
          </a>
          <a
            href="/get-involved"
            class="inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-white/80 px-6 py-3 text-sm font-semibold text-[var(--fg)] transition hover:border-[var(--brand-navy)] hover:bg-white"
          >
            Volunteer with us
          </a>
        </div>
      </div>
      <div class="hero-image">
        <img
          src={bento1.src}
          alt="Education programme placeholder"
          width="520"
          height="420"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-contain"
        />
      </div>
    </div>
  </section>

  <section class="container-page py-10 sm:py-12">
    <div class="stats-grid">
      {stats.map((stat) => (
        <article class="stat-card">
          <p class="stat-value">{stat.value}</p>
          <p class="stat-label">{stat.label}</p>
          <p class="stat-response">{stat.response}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-center">
      <div class="focus-media">
        <img
          src={bento2.src}
          alt="Learning support placeholder"
          width="480"
          height="360"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-contain"
        />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          What we do
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Practical support that keeps classrooms full.
        </h2>
        <div class="mt-6 grid gap-4">
          {focusAreas.map((area) => (
            <div class="focus-card">
              <h3 class="font-heading text-lg font-semibold text-[var(--fg)]">{area.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{area.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="journey-band">
    <div class="container-page py-12 sm:py-14">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          Programme journey
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          From learning gaps to lasting progress.
        </h2>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {journey.map((step, index) => (
          <div class="journey-card">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--muted)]">
              Step {index + 1}
            </p>
            <h3 class="mt-3 font-heading text-lg font-semibold text-[var(--fg)]">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="initiatives-header">
      <p class="initiatives-eyebrow">Initiatives</p>
      <h2 class="initiatives-heading">How LBD is closing the gap for children.</h2>
      <p class="initiatives-subcopy">
        From community classrooms to creative learning spaces and Sunday schools, these initiatives help children
        move from illiteracy and isolation into joyful learning.
      </p>
    </div>
    <div class="initiatives-grid">
      {initiatives.map((item) => (
        <article class="initiative-card">
          <div class="initiative-media">
            <img
              src={item.image.src}
              alt={item.title}
              loading="lazy"
              decoding="async"
              class="initiative-img"
            />
          </div>
          <div class="initiative-body">
            <p class="initiative-tag">{item.tag}</p>
            <h3 class="initiative-title">{item.title}</h3>
            <p class="initiative-text">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          Impact gallery
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Real moments from our learning spaces.
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--muted)] sm:text-base">
          Replace these placeholders with your programme photos to show classrooms, mentors, and learning hubs.
        </p>
      </div>
      <div class="bento-grid">
        <div class="bento-card bento-tall">
          <img
            src={bento3.src}
            alt="Learning moment placeholder"
            width="420"
            height="520"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
        <div class="bento-card">
          <img
            src={bento4.src}
            alt="Classroom activity placeholder"
            width="420"
            height="320"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
        <div class="bento-card">
          <img
            src={bento5.src}
            alt="Learning resources placeholder"
            width="420"
            height="320"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
        <div class="bento-card bento-wide">
          <img
            src={bento6.src}
            alt="Community learning placeholder"
            width="520"
            height="320"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="cta-panel">
      <div>
        <h2 class="font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Help a child stay in school.
        </h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--muted)] sm:text-base">
          Your support funds learning materials, nutrition, and the educators who keep children motivated.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="/donate"
          class="inline-flex items-center justify-center rounded-full bg-[var(--brand-navy)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[color-mix(in_srgb,var(--brand-navy)_85%,black)]"
        >
          Donate for education
        </a>
        <a
          href="/get-involved"
          class="inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-white px-6 py-3 text-sm font-semibold text-[var(--fg)] transition hover:border-[var(--brand-navy)]"
        >
          Explore volunteering
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .education-hero {
    background: #f3fbff;
  }

  .hero-image {
    border-radius: 28px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 2rem;
    box-shadow: 0 18px 40px rgba(12, 16, 34, 0.08);
  }

  .stats-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .stat-card {
    position: relative;
    border-radius: 20px;
    padding: 1.2rem 1.4rem;
    color: #ffffff;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--brand-cyan) 80%, white) 0%,
      color-mix(in srgb, var(--brand-cyan) 55%, white) 100%
    );
    box-shadow: 0 14px 26px rgba(15, 23, 42, 0.22);
    overflow: hidden;
  }

  .stat-card:nth-child(2) {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--brand-orange) 80%, white) 0%,
      color-mix(in srgb, var(--brand-orange) 55%, white) 100%
    );
  }

  .stat-card:nth-child(3) {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--brand-pink) 80%, white) 0%,
      color-mix(in srgb, var(--brand-pink) 55%, white) 100%
    );
  }

  .stat-value {
    font-family: Poppins, Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .stat-label {
    margin-top: 0.35rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.9;
  }

  .stat-response {
    margin-top: 0.7rem;
    font-size: 0.86rem;
    line-height: 1.55;
    color: color-mix(in srgb, white 88%, transparent);
  }

  .focus-media {
    border-radius: 24px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.5rem;
    box-shadow: 0 16px 32px rgba(12, 16, 34, 0.08);
  }

  .focus-card {
    border-radius: 18px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1rem 1.2rem;
    box-shadow: 0 10px 18px rgba(12, 16, 34, 0.06);
  }

  .journey-band {
    background: #FF8C00;
  }

  .journey-card {
    border-radius: 20px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.2rem 1.3rem;
    box-shadow: 0 12px 20px rgba(12, 16, 34, 0.06);
  }

  .cta-panel {
    border-radius: 28px;
    border: 1px solid var(--border);
    background: #e9fbf7;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .initiatives-header {
    max-width: 44rem;
    margin-inline: auto;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .initiatives-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--brand-navy) 80%, var(--muted));
  }

  .initiatives-heading {
    margin-top: 0.75rem;
    font-family: Poppins, Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 600;
    color: var(--fg);
  }

  .initiatives-subcopy {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .initiatives-grid {
    display: grid;
    gap: 1.4rem;
  }

  @media (min-width: 768px) {
    .initiatives-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .initiative-card {
    display: flex;
    flex-direction: column;
    border-radius: 24px;
    background: #ffffff;
    border: 1px solid var(--border);
    box-shadow: 0 14px 26px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .initiative-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .initiative-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .initiative-body {
    padding: 1.1rem 1.2rem 1.2rem;
  }

  .initiative-tag {
    display: inline-flex;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--brand-navy) 82%, black);
    background: color-mix(in srgb, var(--brand-lime) 16%, #f3fbff);
  }

  .initiative-title {
    margin-top: 0.7rem;
    font-family: Poppins, Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--fg);
  }

  .initiative-text {
    margin-top: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .bento-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .bento-card {
    border-radius: 22px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.2rem;
    box-shadow: 0 12px 22px rgba(12, 16, 34, 0.08);
  }

  .bento-tall {
    grid-row: span 2;
  }

  .bento-wide {
    grid-column: span 2;
  }

  @media (min-width: 768px) {
    .bento-grid {
      gap: 1.1rem;
    }
  }

  @media (min-width: 768px) {
    .cta-panel {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>

