---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import img1 from "../../images/programmes/disaster_response/img1.jpeg";
import img2 from "../../images/programmes/disaster_response/img2.jpeg";
import img3 from "../../images/programmes/disaster_response/img3.jpeg";
import img4 from "../../images/programmes/disaster_response/img4.jpeg";
import img5 from "../../images/programmes/disaster_response/img5.jpeg";
import img6 from "../../images/programmes/disaster_response/img6.jpeg";
import img7 from "../../images/programmes/disaster_response/img7.jpeg";
import img8 from "../../images/programmes/disaster_response/img8.jpeg";
import img9 from "../../images/programmes/disaster_response/img9.jpeg";

const timelinePhases = [
  {
    phase: "01",
    title: "Prepare",
    description: "Community risk mapping, early warning systems, and trained local responders so when crisis hits, we're ready.",
  },
  {
    phase: "02",
    title: "Respond",
    description: "Immediate relief: emergency shelter, food, water, and medical support in the critical first hours and days.",
  },
  {
    phase: "03",
    title: "Relief",
    description: "Ongoing distribution of essentials, temporary shelters, and psychosocial support for displaced families.",
  },
  {
    phase: "04",
    title: "Recover",
    description: "Help communities rebuild livelihoods, repair infrastructure, and restore access to education and health.",
  },
  {
    phase: "05",
    title: "Rebuild",
    description: "Long-term resilience: stronger shelters, better systems, and community capacity for future disasters.",
  },
];

const focusCards = [
  {
    title: "Preparation",
    subtitle: "Before disaster strikes",
    description: "We train local responders, map evacuation routes, and partner with communities so they know what to do when the unexpected happens.",
    icon: "prepare",
  },
  {
    title: "Immediate Response",
    subtitle: "First 72 hours and beyond",
    description: "When disaster hits, we mobilize quickly—emergency kits, shelter materials, food and water distribution, and medical triage where needed.",
    icon: "respond",
  },
  {
    title: "Long-term Effects",
    subtitle: "Recovery and resilience",
    description: "We stay after the headlines fade. Rebuilding homes, restoring livelihoods, and strengthening communities so they bounce back stronger.",
    icon: "rebuild",
  },
];

const galleryItems = [
  { src: img1, alt: "Disaster response relief distribution" },
  { src: img2, alt: "Community support during crisis" },
  { src: img3, alt: "Relief effort and emergency support" },
  { src: img4, alt: "Recovery and rebuilding efforts" },
  { src: img5, alt: "Community resilience in action" },
  { src: img6, alt: "" },
];
---

<Layout
  title="Disaster Response | Living Branch Development"
  description="Living Branch disaster response: prepare, respond, and rebuild. Emergency relief, recovery support, and long-term resilience for communities in Pakistan."
>
  <div class="disaster-response">
    <!-- Hero: urgent, operational, amber accent -->
    <section class="disaster-hero">
      <div class="disaster-hero-bg" aria-hidden="true"></div>
      <div class="container-page relative z-10 py-16 md:py-20 lg:py-24">
        <div class="disaster-hero-grid">
          <div>
            <p class="disaster-badge">
              <span class="disaster-badge-dot" aria-hidden="true"></span>
              Disaster Response
            </p>
            <h1 class="disaster-heading">
              Prepare. Respond. Rebuild.
            </h1>
            <p class="disaster-lead">
              When disasters strike—floods, earthquakes, displacement—we mobilise quickly. From immediate relief to long-term resilience, we stand with communities before, during, and long after the crisis.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="/donate" class="disaster-cta-primary">
                Support relief efforts
              </a>
              <a href="/get-involved" class="disaster-cta-secondary">
                Volunteer
              </a>
            </div>
          </div>
          <div class="disaster-hero-image-card">
            <Image
              src={img1}
              alt="Disaster response relief and community support"
              width={560}
              height={420}
              priority
              widths={[360, 480, 560, 640]}
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 560px"
              quality={80}
              class="disaster-hero-img"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Response Timeline: wave/flow -->
    <section class="response-timeline-surface" aria-labelledby="timeline-heading">
      <div class="container-page py-14 md:py-16">
        <div class="timeline-header">
          <p class="timeline-eyebrow">Response phases</p>
          <h2 id="timeline-heading" class="timeline-title">
            From crisis to resilience—every step matters.
          </h2>
        </div>

        <!-- Desktop: horizontal wave timeline -->
        <div class="timeline-horizontal hidden lg:block">
          <div class="timeline-wave-line" aria-hidden="true"></div>
          <div class="timeline-phases">
            {timelinePhases.map((phase, i) => (
              <article class="timeline-phase-card" data-reveal>
                <span class="timeline-phase-num">{phase.phase}</span>
                <h3 class="timeline-phase-title">{phase.title}</h3>
                <p class="timeline-phase-desc">{phase.description}</p>
              </article>
            ))}
          </div>
        </div>

        <!-- Mobile: vertical timeline -->
        <div class="timeline-vertical mt-10 lg:hidden">
          <div class="timeline-wave-vertical" aria-hidden="true"></div>
          {timelinePhases.map((phase, i) => (
            <article class="timeline-phase-card timeline-phase-vertical" data-reveal>
              <span class="timeline-phase-num">{phase.phase}</span>
              <h3 class="timeline-phase-title">{phase.title}</h3>
              <p class="timeline-phase-desc">{phase.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Focus cards: Preparation, Immediate Response, Long-term -->
    <section class="container-page py-14 md:py-16">
      <div class="focus-header">
        <p class="focus-eyebrow">How we work</p>
        <h2 class="focus-title">
          Three pillars of disaster response.
        </h2>
      </div>
      <div class="focus-cards">
        {focusCards.map((card, i) => (
          <article class="focus-card" data-reveal style={`--reveal-delay: ${i * 120}ms`}>
            <div class="focus-card-inner">
              <span class="focus-card-subtitle">{card.subtitle}</span>
              <h3 class="focus-card-title">{card.title}</h3>
              <p class="focus-card-desc">{card.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Split: image + impact snapshot -->
    <section class="disaster-split-surface">
      <div class="container-page py-14 md:py-16">
        <div class="disaster-split-grid">
          <div class="disaster-split-media">
            <Image
              src={img2}
              alt="Community disaster response in action"
              width={560}
              height={420}
              loading="lazy"
              widths={[360, 480, 560]}
              sizes="(max-width: 768px) 100vw, 50vw"
              quality={80}
              class="disaster-split-img"
            />
          </div>
          <div>
            <p class="focus-eyebrow">Impact snapshot</p>
            <h2 class="focus-title mt-2">
              Rapid response, lasting impact.
            </h2>
            <p class="disaster-split-text">
              We work with local leaders and volunteers to deliver help where it's needed most. Our teams have supported communities through floods, displacement, and emergencies—providing essential supplies, shelter materials, and ongoing psychosocial support.
            </p>
            <ul class="disaster-split-list">
              <li>Emergency kits and shelter materials</li>
              <li>Food and water distribution</li>
              <li>Psychosocial support for affected families</li>
              <li>Livelihood recovery and rebuilding support</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Gallery: staggered grid -->
    <section class="container-page py-14 md:py-16">
      <div class="gallery-header">
        <p class="focus-eyebrow">Field moments</p>
        <h2 class="focus-title">
          Relief and recovery in action.
        </h2>
      </div>
      <div class="disaster-gallery">
        {galleryItems.map((item, i) => (
          <div class={`gallery-item gallery-item-${i + 1}`} data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <Image
              src={item.src}
              alt={item.alt}
              width={400}
              height={300}
              loading="lazy"
              widths={[240, 320, 400]}
              sizes="(max-width: 640px) 50vw, 33vw"
              quality={80}
              class="gallery-img"
            />
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="container-page py-14 md:py-16">
      <div class="disaster-cta-panel">
        <div>
          <h2 class="font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
            Help communities when they need it most.
          </h2>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--muted)] sm:text-base">
            Your support funds emergency relief, shelter materials, and long-term recovery for families affected by disaster.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href="/donate"
            class="disaster-cta-primary"
          >
            Donate for disaster relief
          </a>
          <a
            href="/get-involved"
            class="disaster-cta-secondary"
          >
            Get involved
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .disaster-response {
    --dr-orange: var(--brand-orange);
    --dr-orange-light: #fff4eb;
    --dr-orange-muted: #ffe8d9;
    --dr-orange-dark: color-mix(in srgb, var(--brand-orange) 75%, black);
    --dr-ink: #1a0d00;
  }

  /* Hero */
  .disaster-hero {
    position: relative;
    overflow: hidden;
  }

  .disaster-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1100px 480px at 12% 20%, var(--dr-orange-muted), transparent 58%),
      radial-gradient(900px 400px at 88% 30%, var(--dr-orange-light), transparent 62%),
      linear-gradient(180deg, #fff8f0, #ffffff 70%);
    z-index: 0;
  }

  .disaster-hero-grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .disaster-hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .disaster-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dr-orange-dark);
    background: var(--dr-orange-light);
    border: 1px solid color-mix(in srgb, var(--dr-orange) 35%, white);
  }

  .disaster-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dr-orange);
  }

  .disaster-heading {
    margin-top: 1rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--dr-ink);
  }

  .disaster-lead {
    margin-top: 1.25rem;
    max-width: 36rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
  }

  @media (min-width: 640px) {
    .disaster-lead {
      font-size: 1.1rem;
    }
  }

  .disaster-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    background: var(--dr-orange);
    box-shadow: 0 4px 14px color-mix(in srgb, var(--dr-orange) 40%, transparent);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .disaster-cta-primary:hover {
    background: color-mix(in srgb, var(--dr-orange) 88%, black);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--dr-orange) 35%, transparent);
  }

  .disaster-cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--dr-orange);
    border: 1px solid color-mix(in srgb, var(--dr-orange) 45%, white);
    background: white;
    transition: background 0.2s, border-color 0.2s;
  }

  .disaster-cta-secondary:hover {
    background: var(--dr-orange-light);
    border-color: color-mix(in srgb, var(--dr-orange) 55%, white);
  }

  .disaster-hero-image-card {
    border-radius: 24px;
    border: 1px solid var(--border);
    background: white;
    padding: 1.25rem;
    box-shadow: 0 18px 40px rgba(12, 16, 34, 0.08);
    overflow: hidden;
  }

  .disaster-hero-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 14px;
  }

  /* Response Timeline */
  .response-timeline-surface {
    background: linear-gradient(180deg, #ffc999 0%, #ffd9b3 40%, #fff4eb 100%);
  }

  .timeline-header {
    max-width: 36rem;
  }

  .timeline-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dr-orange-dark);
  }

  .timeline-title {
    margin-top: 0.5rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--fg);
  }

  /* Horizontal timeline */
  .timeline-horizontal {
    margin-top: 2.5rem;
    position: relative;
  }

  .timeline-wave-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 4px;
    transform: translateY(-50%);
    background: linear-gradient(
      90deg,
      var(--dr-orange) 0%,
      #ff8c4a 50%,
      var(--dr-orange) 100%
    );
    border-radius: 2px;
    opacity: 0.95;
  }

  .timeline-phases {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .timeline-phase-card {
    padding: 1.25rem 1rem;
    border-radius: 18px;
    background: white;
    border: 1px solid var(--border);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  .timeline-phase-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-phase-num {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--dr-orange);
  }

  .timeline-phase-title {
    margin-top: 0.4rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
  }

  .timeline-phase-desc {
    margin-top: 0.5rem;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--muted);
  }

  /* Vertical timeline */
  .timeline-vertical {
    position: relative;
    padding-left: 1.5rem;
  }

  .timeline-wave-vertical {
    position: absolute;
    left: 0.2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 4px;
    background: linear-gradient(
      to bottom,
      var(--dr-orange),
      #ff9d5c
    );
    border-radius: 2px;
  }

  .timeline-phase-vertical {
    margin-bottom: 1.5rem;
  }

  /* Focus cards */
  .focus-header {
    margin-bottom: 2rem;
  }

  .focus-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dr-orange-dark);
  }

  .focus-title {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--fg);
  }

  .focus-cards {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .focus-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .focus-card {
    padding: 1.5rem;
    border-radius: 20px;
    background: white;
    border: 1px solid var(--border);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.2s;
    transition-delay: var(--reveal-delay, 0ms);
  }

  .focus-card:hover {
    box-shadow: 0 14px 32px rgba(255, 106, 26, 0.08);
  }

  .focus-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .focus-card-inner {
    padding-left: 0.75rem;
    border-left: 3px solid var(--dr-orange);
  }

  .focus-card-subtitle {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .focus-card-title {
    margin-top: 0.4rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--fg);
  }

  .focus-card-desc {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Split section */
  .disaster-split-surface {
    background: var(--dr-orange-light);
  }

  .disaster-split-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .disaster-split-grid {
      grid-template-columns: 0.95fr 1.05fr;
    }
  }

  .disaster-split-media {
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.08);
  }

  .disaster-split-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .disaster-split-text {
    margin-top: 1rem;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .disaster-split-list {
    margin-top: 1.25rem;
    padding-left: 1.25rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--muted);
  }

  .disaster-split-list li {
    margin-bottom: 0.35rem;
  }

  /* Gallery */
  .gallery-header {
    margin-bottom: 2rem;
  }

  .disaster-gallery {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 640px) {
    .disaster-gallery {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .gallery-item {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
    opacity: 0;
    transform: scale(0.97);
    transition: opacity 0.4s ease, transform 0.4s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  .gallery-item.visible {
    opacity: 1;
    transform: scale(1);
  }

  .gallery-item-1 {
    grid-column: span 2;
  }

  @media (min-width: 640px) {
    .gallery-item-1 {
      grid-column: span 1;
      grid-row: span 2;
    }
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-item-1 .gallery-img {
    min-height: 220px;
  }

  @media (min-width: 640px) {
    .gallery-item-1 .gallery-img {
      min-height: 100%;
    }
  }

  /* CTA panel */
  .disaster-cta-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    border-radius: 24px;
    background: var(--dr-orange-light);
    border: 1px solid color-mix(in srgb, var(--dr-orange) 25%, white);
  }

  @media (min-width: 768px) {
    .disaster-cta-panel {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-phase-card,
    .focus-card,
    .gallery-item {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  if (typeof window !== "undefined" && "IntersectionObserver" in window) {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!prefersReduced) {
      const revealEls = document.querySelectorAll("[data-reveal]");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -30px 0px" }
      );
      revealEls.forEach((el) => observer.observe(el));
    } else {
      document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("visible"));
    }
  }
</script>
