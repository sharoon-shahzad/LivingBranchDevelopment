---
import Layout from "../../layouts/Layout.astro";
import HeroImageUrl from "../../images/placeholders/impact-4.svg?url";
import womenImg2 from "../../images/programmes/women_empowerment/women_empowerment2.jpeg";
import womenImg3 from "../../images/programmes/women_empowerment/women_empowerment3.jpeg";
import womenImg4 from "../../images/programmes/women_empowerment/women_empowerment4.jpeg";
import womenImg5 from "../../images/programmes/women_empowerment/women_empowerment5.jpeg";
import womenImg6 from "../../images/programmes/women_empowerment/women_empowerment6.jpeg";

const barriers = [
  {
    title: "Limited education & skills",
    description: "Many women and girls lack access to quality education and market-ready skills, limiting their options.",
    livingBranch: "We run skills training, apprenticeships, and literacy programmes in community hubs so women can build confidence and earn.",
    icon: "education",
  },
  {
    title: "Economic dependency",
    description: "Without access to capital or income, women often remain financially dependent and unable to make choices.",
    livingBranch: "Savings circles, micro-grants, and mentor networks give women the tools to save, invest, and grow their own enterprises.",
    icon: "economic",
  },
  {
    title: "Safety & protection gaps",
    description: "Gender-based violence, harassment, and lack of safe spaces prevent women from participating fully.",
    livingBranch: "Trauma-informed counselling, legal referrals, and safe community spaces where women can heal and access support.",
    icon: "safety",
  },
  {
    title: "Limited voice & leadership",
    description: "Cultural norms often exclude women from decision-making and leadership roles.",
    livingBranch: "Advocacy training, women-led committees, and peer networks so women gain voice and influence in their communities.",
    icon: "voice",
  },
];

const galleryItems = [
  { src: womenImg2, alt: "Women in skills training", label: "Skills & training" },
  { src: womenImg3, alt: "Women in savings circle", label: "Economic empowerment" },
  { src: womenImg4, alt: "Women in safe community space", label: "Safe spaces" },
  { src: womenImg5, alt: "Women leading community session", label: "Leadership in action" },
  { src: womenImg6, alt: "Women thriving together", label: "Community" },
];
---

<Layout title="Women Empowerment | Living Branch Development">
  <div class="women-empowerment">
    <section class="hero-surface">
      <div class="container-page grid gap-12 py-16 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.36em] text-[var(--women-pink)]">
            Women Empowerment
          </p>
          <h1 class="font-heading mt-4 text-4xl font-semibold tracking-tight text-[var(--women-ink)] sm:text-5xl">
            Build power, income, and leadership for every woman.
          </h1>
          <p class="mt-5 max-w-2xl text-lg text-[var(--women-muted)]">
            We partner with women and girls to expand safety, skills, and opportunity through holistic programmes
            that strengthen families and local economies.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/get-involved"
              class="primary-cta rounded-full px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              Join the movement
            </a>
            <a
              href="/donate"
              class="secondary-cta rounded-full border px-6 py-3 text-sm font-semibold transition hover:-translate-y-0.5"
            >
              Support a woman today
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="float-card rounded-3xl bg-white p-6 shadow-lg" style="--float-dur: 9s">
            <img
              src={HeroImageUrl}
              alt="Women leading a community skills session"
              class="h-64 w-full rounded-2xl object-cover"
              loading="lazy"
            />
            <div class="mt-6 grid gap-4 sm:grid-cols-3">
              <div class="stat-card rounded-2xl border p-4 text-center">
                <span class="stat-value block text-2xl font-semibold">3,200+</span>
                <span class="stat-label mt-1 block text-xs uppercase tracking-[0.2em]">Women trained</span>
              </div>
              <div class="stat-card rounded-2xl border p-4 text-center">
                <span class="stat-value block text-2xl font-semibold">54%</span>
                <span class="stat-label mt-1 block text-xs uppercase tracking-[0.2em]">Income growth</span>
              </div>
              <div class="stat-card rounded-2xl border p-4 text-center">
                <span class="stat-value block text-2xl font-semibold">18</span>
                <span class="stat-label mt-1 block text-xs uppercase tracking-[0.2em]">Community hubs</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What women face in Pakistan + How LBD responds -->
    <section class="barriers-surface" aria-labelledby="barriers-heading">
      <div class="container-page py-14 md:py-16">
        <div class="barriers-header">
          <p class="barriers-eyebrow">What women face in Pakistan</p>
          <h2 id="barriers-heading" class="barriers-title">
            Barriers we break. Support we provide.
          </h2>
          <p class="barriers-intro">
            Women and girls across Pakistan face systemic barriers. Here’s how LBD responds to each.
          </p>
        </div>
        <div class="barriers-grid">
          {barriers.map((b, i) => (
            <article class="barrier-card" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
              <div class="barrier-card-top">
                <span class="barrier-icon" aria-hidden="true">
                  {b.icon === "education" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                      <path d="M8 7h8"/>
                      <path d="M8 11h8"/>
                    </svg>
                  )}
                  {b.icon === "economic" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="1" x2="12" y2="23"/>
                      <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                  )}
                  {b.icon === "safety" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  )}
                  {b.icon === "voice" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m3 11 18-5v12L3 14v-3z"/>
                      <path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/>
                    </svg>
                  )}
                </span>
                <div>
                  <h3 class="barrier-title">{b.title}</h3>
                  <p class="barrier-desc">{b.description}</p>
                </div>
              </div>
              <div class="barrier-arrow" aria-hidden="true">
                <span class="barrier-arrow-icon">→</span>
              </div>
              <div class="barrier-response">
                <p class="barrier-response-label">How LBD responds</p>
                <p class="barrier-response-text">{b.livingBranch}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Image gallery: validates barriers section -->
    <section class="gallery-surface" aria-labelledby="gallery-heading">
      <div class="container-page py-14 md:py-16">
        <div class="gallery-header">
          <p class="barriers-eyebrow">See our work</p>
          <h2 id="gallery-heading" class="barriers-title">
            Women thriving—in pictures.
          </h2>
          <p class="barriers-intro">
            Real moments from our community hubs: skills training, safe spaces, and women leading change.
          </p>
        </div>
        <div class="women-gallery">
          {galleryItems.map((item, i) => (
            <figure class={`women-gallery-item women-gallery-item-${i + 1}`} data-reveal style={`--reveal-delay: ${i * 80}ms`}>
              <div class="women-gallery-img-wrap">
                <img
                  src={item.src.src}
                  alt={item.alt}
                  width={400}
                  height={300}
                  loading="lazy"
                  decoding="async"
                  class="women-gallery-img"
                />
              </div>
              <figcaption class="women-gallery-caption">{item.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="container-page py-16">
      <div class="grid gap-8 rounded-3xl border border-[var(--women-border)] bg-white p-8 shadow-sm lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.36em] text-[var(--women-pink)]">Impact snapshot</p>
          <h2 class="font-heading mt-4 text-3xl font-semibold text-[var(--women-ink)]">
            From survivor support to thriving enterprises.
          </h2>
          <p class="mt-4 text-[var(--women-muted)]">
            Our women-first model combines protection services, livelihood acceleration, and leadership coaching
            so every participant can move from crisis to confidence.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="mini-card rounded-2xl p-5">
            <p class="text-sm font-semibold text-[var(--women-ink)]">Safety + Healing</p>
            <p class="mt-2 text-sm text-[var(--women-muted)]">Trauma-informed counseling and legal referrals.</p>
          </div>
          <div class="mini-card rounded-2xl p-5">
            <p class="text-sm font-semibold text-[var(--women-ink)]">Skills + Jobs</p>
            <p class="mt-2 text-sm text-[var(--women-muted)]">Market-ready skills, apprenticeships, and coaching.</p>
          </div>
          <div class="mini-card rounded-2xl p-5">
            <p class="text-sm font-semibold text-[var(--women-ink)]">Capital Access</p>
            <p class="mt-2 text-sm text-[var(--women-muted)]">Savings circles, micro-grants, and mentor networks.</p>
          </div>
          <div class="mini-card rounded-2xl p-5">
            <p class="text-sm font-semibold text-[var(--women-ink)]">Leadership</p>
            <p class="mt-2 text-sm text-[var(--women-muted)]">Community advocacy and women-led committees.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bloom-surface py-16">
      <div class="container-page">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.36em] text-[var(--women-pink)]">
              Bloom map
            </p>
            <h2 class="font-heading mt-4 text-3xl font-semibold text-[var(--women-ink)] sm:text-4xl">
              Women thrive when every support system blooms together.
            </h2>
            <p class="mt-4 text-[var(--women-muted)]">
              Each petal represents a core pillar of our work. Together, they surround the woman at the
              center, creating a full circle of protection, opportunity, and leadership.
            </p>
            <div class="mt-6 grid gap-3 text-sm text-[var(--women-muted)]">
              <p><span class="font-semibold text-[var(--women-ink)]">Empowerment focus:</span> safety, skills, income, and voice.</p>
              <p><span class="font-semibold text-[var(--women-ink)]">Delivery model:</span> community hubs led by women mentors.</p>
            </div>
          </div>
          <div class="bloom-map" aria-label="Women empowerment program pillars">
            <div class="bloom-petal bloom-n" role="listitem">
              <span class="bloom-title">Safety + Healing</span>
              <span class="bloom-copy">Counseling, legal support, and crisis care.</span>
            </div>
            <div class="bloom-petal bloom-ne" role="listitem">
              <span class="bloom-title">Skills + Jobs</span>
              <span class="bloom-copy">Training, apprenticeships, and placement.</span>
            </div>
            <div class="bloom-petal bloom-se" role="listitem">
              <span class="bloom-title">Capital Access</span>
              <span class="bloom-copy">Savings circles and micro-grants.</span>
            </div>
            <div class="bloom-petal bloom-s" role="listitem">
              <span class="bloom-title">Enterprise</span>
              <span class="bloom-copy">Business coaching and market linkages.</span>
            </div>
            <div class="bloom-petal bloom-sw" role="listitem">
              <span class="bloom-title">Leadership</span>
              <span class="bloom-copy">Advocacy training and community seats.</span>
            </div>
            <div class="bloom-petal bloom-nw" role="listitem">
              <span class="bloom-title">Network</span>
              <span class="bloom-copy">Peer mentors and alumni circles.</span>
            </div>
            <div class="bloom-center" aria-label="Women Thrive">Women Thrive</div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  :global(.women-empowerment) {
    --women-pink: var(--brand-pink);
    --women-ink: #1a0b2e;
    --women-muted: #5d5667;
    --women-border: color-mix(in srgb, var(--brand-pink) 18%, white);
  }

  :global(.women-empowerment .hero-surface) {
    background:
      radial-gradient(1100px 520px at 18% 12%, color-mix(in srgb, var(--brand-pink) 14%, white), transparent 62%),
      radial-gradient(900px 520px at 82% 20%, color-mix(in srgb, var(--brand-pink) 8%, white), transparent 70%),
      linear-gradient(180deg, #fff, color-mix(in srgb, var(--brand-pink) 4%, white));
  }

  :global(.women-empowerment .primary-cta) {
    background: var(--women-pink);
  }

  :global(.women-empowerment .secondary-cta) {
    color: var(--women-pink);
    border-color: color-mix(in srgb, var(--brand-pink) 40%, white);
  }

  :global(.women-empowerment .secondary-cta:hover) {
    background: color-mix(in srgb, var(--brand-pink) 8%, white);
  }

  :global(.women-empowerment .stat-card) {
    background: var(--women-pink);
    border-color: transparent;
    box-shadow: 0 14px 28px rgba(255, 0, 122, 0.18);
  }

  :global(.women-empowerment .stat-value) {
    color: white;
  }

  :global(.women-empowerment .stat-label) {
    color: color-mix(in srgb, white 82%, var(--brand-pink));
  }

  :global(.women-empowerment .mini-card) {
    background: color-mix(in srgb, var(--brand-pink) 8%, white);
    border: 1px solid color-mix(in srgb, var(--brand-pink) 16%, white);
  }

  /* Barriers + LBD Response section */
  :global(.women-empowerment .barriers-surface) {
    background: color-mix(in srgb, var(--brand-pink) 6%, white);
  }

  :global(.women-empowerment .barriers-header) {
    max-width: 40rem;
    margin-bottom: 2rem;
  }

  :global(.women-empowerment .barriers-eyebrow) {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--women-pink);
  }

  :global(.women-empowerment .barriers-title) {
    margin-top: 0.5rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--women-ink);
  }

  :global(.women-empowerment .barriers-intro) {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--women-muted);
  }

  :global(.women-empowerment .barriers-grid) {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    :global(.women-empowerment .barriers-grid) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  :global(.women-empowerment .barrier-card) {
    display: grid;
    grid-template-rows: auto auto auto;
    grid-template-areas:
      "top"
      "arrow"
      "response";
    gap: 1rem;
    padding: 1.5rem;
    background: white;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--brand-pink) 18%, white);
    box-shadow: 0 10px 28px rgba(255, 0, 122, 0.06);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  :global(.women-empowerment .barrier-card.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    :global(.women-empowerment .barrier-card) {
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: 1fr;
      grid-template-areas: "top arrow response";
      align-items: center;
      gap: 1.25rem;
    }
  }

  :global(.women-empowerment .barrier-card-top) {
    grid-area: top;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  :global(.women-empowerment .barrier-icon) {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--brand-pink) 12%, white);
    color: var(--women-pink);
  }

  :global(.women-empowerment .barrier-title) {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--women-ink);
  }

  :global(.women-empowerment .barrier-desc) {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--women-muted);
    margin-top: 0.35rem;
  }

  :global(.women-empowerment .barrier-arrow) {
    grid-area: arrow;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  @media (min-width: 768px) {
    :global(.women-empowerment .barrier-arrow) {
      justify-content: center;
    }
  }

  :global(.women-empowerment .barrier-arrow-icon) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--women-pink);
  }

  @media (max-width: 767px) {
    :global(.women-empowerment .barrier-arrow-icon) {
      transform: rotate(90deg);
      display: inline-block;
    }
  }

  :global(.women-empowerment .barrier-response) {
    grid-area: response;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--brand-pink) 8%, white);
    border-radius: 1rem;
    border-left: 4px solid var(--women-pink);
  }

  :global(.women-empowerment .barrier-response-label) {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--women-pink);
    margin-bottom: 0.4rem;
  }

  :global(.women-empowerment .barrier-response-text) {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--women-ink);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.women-empowerment .barrier-card) {
      opacity: 1;
      transform: none;
    }
  }

  /* Image gallery */
  :global(.women-empowerment .gallery-surface) {
    background: white;
  }

  :global(.women-empowerment .gallery-header) {
    max-width: 40rem;
    margin-bottom: 2rem;
  }

  :global(.women-empowerment .women-gallery) {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 640px) {
    :global(.women-empowerment .women-gallery) {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  :global(.women-empowerment .women-gallery-item) {
    margin: 0;
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--brand-pink) 16%, white);
    box-shadow: 0 8px 24px rgba(255, 0, 122, 0.06);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease, box-shadow 0.2s;
    transition-delay: var(--reveal-delay, 0ms);
  }

  :global(.women-empowerment .women-gallery-item:hover) {
    box-shadow: 0 12px 32px rgba(255, 0, 122, 0.1);
  }

  :global(.women-empowerment .women-gallery-item.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.women-empowerment .women-gallery-item-1) {
    grid-column: span 2;
  }

  @media (min-width: 640px) {
    :global(.women-empowerment .women-gallery-item-1) {
      grid-column: span 1;
      grid-row: span 2;
    }
  }

  :global(.women-empowerment .women-gallery-img-wrap) {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
  }

  :global(.women-empowerment .women-gallery-item-1 .women-gallery-img-wrap) {
    min-height: 200px;
  }

  @media (min-width: 640px) {
    :global(.women-empowerment .women-gallery-item-1 .women-gallery-img-wrap) {
      aspect-ratio: auto;
      flex: 1;
      min-height: 0;
    }
  }

  :global(.women-empowerment .women-gallery-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  :global(.women-empowerment .women-gallery-caption) {
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--women-pink);
    background: color-mix(in srgb, var(--brand-pink) 8%, white);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.women-empowerment .women-gallery-item) {
      opacity: 1;
      transform: none;
    }
  }

  :global(.women-empowerment .bloom-surface) {
    background:
      radial-gradient(900px 480px at 20% 15%, color-mix(in srgb, var(--brand-pink) 14%, white), transparent 65%),
      radial-gradient(900px 480px at 80% 20%, color-mix(in srgb, var(--brand-pink) 10%, white), transparent 68%),
      #fff;
  }

  :global(.women-empowerment .bloom-map) {
    position: relative;
    margin: 0 auto;
    height: min(82vw, 420px);
    width: min(82vw, 420px);
  }

  :global(.women-empowerment .bloom-petal) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(46vw, 220px);
    height: min(30vw, 140px);
    padding: 1rem 1.1rem;
    border-radius: 999px;
    background: white;
    color: var(--women-pink);
    border: 1px solid color-mix(in srgb, var(--brand-pink) 35%, white);
    box-shadow: 0 18px 40px rgba(255, 0, 122, 0.12);
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
    gap: 0.35rem;
    z-index: 1;
  }

  :global(.women-empowerment .bloom-title) {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;

  }

  :global(.women-empowerment .bloom-copy) {
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--brand-pink) 70%, #4a0030);
  }

  :global(.women-empowerment .bloom-center) {
    position: absolute;
