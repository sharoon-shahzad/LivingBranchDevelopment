<script>
  (function() {
    if (typeof window === "undefined") return;
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function initReveal() {
      if (prefersReduced) {
        document.querySelectorAll("[data-reveal], [data-reveal-item], .barrier-item, .bridge-card, .path-step, .space-feature, .proof-stat, .outcome-card, .proof-gallery-item, .invite-panel, .skills-hero-media, .path-media, .space-media").forEach((el) => el.classList.add("visible"));
        return;
      }
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              const items = e.target.querySelectorAll("[data-reveal-item], .barrier-item, .bridge-card, .path-step, .space-feature, .proof-stat, .outcome-card, .proof-gallery-item");
              items.forEach((item) => item.classList.add("visible"));
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );
      document.querySelectorAll("[data-reveal], [data-chapter]").forEach((el) => observer.observe(el));
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initReveal);
    } else {
      initReveal();
    }
  })();
</script>
