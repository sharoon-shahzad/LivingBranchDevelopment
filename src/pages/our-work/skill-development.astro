---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import heroImg from "../../images/programmes/skill_development/TechHub/hero_skills.jpeg";
import pathImg from "../../images/programmes/skill_development/TechHub/path_img.jpeg";
import spaceImg from "../../images/programmes/skill_development/TechHub/space_img.jpeg";
import gal01 from "../../images/programmes/skill_development/TechHub/gal_01.jpeg";
import gal02 from "../../images/programmes/skill_development/TechHub/gal_02.jpeg";
import gal03 from "../../images/programmes/skill_development/TechHub/gal_03.jpeg";
import gal04 from "../../images/programmes/skill_development/TechHub/gal_04.jpeg";
import gal05 from "../../images/programmes/skill_development/TechHub/gal_05.jpeg";

const chapters = [
  { num: "01", title: "The Gap", id: "ch-gap" },
  { num: "02", title: "The Bridge", id: "ch-bridge" },
  { num: "03", title: "The Path", id: "ch-path" },
  { num: "04", title: "The Space", id: "ch-space" },
  { num: "05", title: "The Proof", id: "ch-proof" },
  { num: "06", title: "The Invite", id: "ch-invite" },
];

const barriers = [
  {
    title: "Limited training access",
    description: "Quality vocational training is out of reach for many.",
    livingBranch: "Community-based TechHub and labs—devices, mentors, and pathways close to home.",
    icon: "access",
  },
  {
    title: "Digital divide",
    description: "No devices, no internet, no digital skills.",
    livingBranch: "Free access to equipment, digital literacy training, and safe internet use.",
    icon: "digital",
  },
  {
    title: "Skills mismatch",
    description: "What's taught doesn't lead to jobs.",
    livingBranch: "Employer-aligned curriculum, placement support, and real-world practice.",
    icon: "match",
  },
  {
    title: "Cost barriers",
    description: "Training is too expensive for those who need it most.",
    livingBranch: "Scholarships and free programmes so talent gets a fair chance.",
    icon: "cost",
  },
];

const curriculum = [
  { title: "Orientation", text: "Goal setting, confidence building, baseline assessments.", icon: "compass" },
  { title: "Hands-on labs", text: "Project-based practice with mentors and peer learning.", icon: "lab" },
  { title: "Certification", text: "Skill evaluation aligned with employer needs.", icon: "cert" },
  { title: "Placement", text: "Hiring connects, entrepreneurship guidance, follow-up.", icon: "rocket" },
];

const techHubFeatures = [
  { title: "Digital literacy", description: "Foundational computer skills, safe internet, workplace tools.", icon: "screen" },
  { title: "Industry labs", description: "Real-world simulations, guided practice, mentors on hand.", icon: "lab" },
  { title: "Career launch", description: "Portfolio building, mock interviews, placement pipelines.", icon: "briefcase" },
];

const outcomes = [
  { value: "900+", label: "Trainees" },
  { value: "60%", label: "Placed" },
  { value: "18", label: "Cohorts" },
];

const outcomeItems = [
  {
    title: "Employment",
    description: "Trainees secure formal jobs and internships through placement support and employer partnerships.",
    icon: "briefcase",
  },
  {
    title: "Entrepreneurship",
    description: "Graduates start small businesses with mentorship, micro-grants, and follow-up guidance.",
    icon: "rocket",
  },
  {
    title: "Digital readiness",
    description: "Learners gain confidence in computers, internet safety, and workplace tools.",
    icon: "screen",
  },
  {
    title: "Confidence & agency",
    description: "Skills and practice build self-belief and readiness to pursue opportunity.",
    icon: "star",
  },
];

const galleryItems = [
  { src: gal01, alt: "Skills lab", label: "Lab practice" },
  { src: gal02, alt: "Mentor session", label: "Mentorship" },
  { src: gal03, alt: "Digital training", label: "Digital skills" },
  { src: gal04, alt: "Community training", label: "Community" },
  { src: gal05, alt: "Teamwork", label: "Collaboration" },
];
---

<Layout
  title="Skill Development | Living Branch Development"
  description="Living Branch skill development: from gap to opportunity. Training, mentorship, and placement for stable livelihoods."
>
  <div class="skills-narrative">
    <!-- Hero -->
    <section class="skills-hero" id="ch-hero">
      <div class="skills-hero-bg-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </div>
      <div class="container-page relative z-10 py-16 lg:py-20">
        <p class="skills-badge">Skill Development</p>
        <h1 class="skills-hero-title">Skills that open pathways to opportunity.</h1>
        <p class="skills-hero-lead">Market-ready training. Mentorship. Placement. We connect talent to stable income.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/donate" class="skills-cta-primary">Support training</a>
          <a href="/get-involved" class="skills-cta-secondary">Become a mentor</a>
        </div>
        <div class="skills-hero-media" data-reveal>
          <Image
            src={heroImg}
            alt="Skill development"
            width={800}
            height={480}
            priority
            widths={[400, 640, 800, 1024, 1280]}
            sizes="(max-width: 768px) 100vw, (max-width: 1024px) 90vw, 800px"
            quality={80}
            class="skills-hero-img"
          />
        </div>
      </div>
    </section>

    <!-- 01 The Gap -->
    <section class="skills-section skills-gap" id="ch-gap" data-chapter>
      <div class="section-bg-icons" aria-hidden="true">
        <span class="bg-icon bg-icon-1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4"><rect width="20" height="14" x="2" y="7" rx="2"/></svg></span>
        <span class="bg-icon bg-icon-2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>
      </div>
      <div class="container-page relative z-10 py-14 md:py-16">
        <div class="chapter-marker">
          <span class="chapter-num">01</span>
          <h2 class="chapter-title">The Gap</h2>
        </div>
        <p class="chapter-tagline">What people face when they want to learn and earn.</p>
        <div class="barriers-grid" data-reveal>
          {barriers.map((b, i) => (
            <article class="barrier-item" data-reveal-item style={`--delay: ${i * 80}ms`}>
              <span class="barrier-icon">
                {b.icon === "access" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                {b.icon === "digital" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>}
                {b.icon === "match" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4"/><path d="m3 3 2 2"/><path d="m21 3 2 2"/><path d="M18 12a6 6 0 0 1-6 6v0a6 6 0 0 1-6-6"/><path d="M12 22v-4"/><path d="m21 21-2-2"/><path d="m3 21-2-2"/></svg>}
                {b.icon === "cost" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
              </span>
              <h3 class="barrier-title">{b.title}</h3>
              <p class="barrier-desc">{b.description}</p>
              <div class="barrier-arrow">→</div>
              <div class="barrier-response">
                <span class="barrier-response-label">LBD responds</span>
                <p>{b.livingBranch}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Transition -->
    <section class="skills-transition">
      <p class="transition-text">LBD builds the bridge.</p>
    </section>

    <!-- 02 The Bridge - compact summary -->
    <section class="skills-section skills-bridge" id="ch-bridge" data-chapter>
      <div class="section-bg-icons" aria-hidden="true">
        <span class="bg-icon bg-icon-3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="4"/></svg></span>
      </div>
      <div class="container-page relative z-10 py-12 md:py-14">
        <div class="chapter-marker">
          <span class="chapter-num">02</span>
          <h2 class="chapter-title">The Bridge</h2>
        </div>
        <p class="chapter-tagline">Foundation skills. Vocational track. Placement support.</p>
        <div class="bridge-cards" data-reveal>
          <div class="bridge-card" data-reveal-item>
            <span class="bridge-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
            <h3>Foundation</h3>
            <p>Literacy, numeracy, workplace readiness.</p>
          </div>
          <div class="bridge-card" data-reveal-item>
            <span class="bridge-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="14" x="2" y="7" rx="2"/></svg></span>
            <h3>Vocational</h3>
            <p>Hands-on training, in-demand trades.</p>
          </div>
          <div class="bridge-card" data-reveal-item>
            <span class="bridge-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
            <h3>Placement</h3>
            <p>Mentorship, interview prep, job links.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 03 The Path -->
    <section class="skills-section skills-path" id="ch-path" data-chapter>
      <div class="section-bg-icons" aria-hidden="true">
        <span class="bg-icon bg-icon-4"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/></svg></span>
      </div>
      <div class="container-page relative z-10 py-14 md:py-16">
        <div class="chapter-marker">
          <span class="chapter-num">03</span>
          <h2 class="chapter-title">The Path</h2>
        </div>
        <p class="chapter-tagline">From training to placement—a clear journey.</p>
        <div class="path-layout">
          <div class="path-media" data-reveal>
            <Image
              src={pathImg}
              alt="Mentor and trainee"
              width={520}
              height={360}
              loading="lazy"
              widths={[320, 480, 520, 640]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 52vw, 520px"
              quality={80}
              class="path-img"
            />
          </div>
          <div class="path-timeline" data-reveal>
            {curriculum.map((step, i) => (
              <div class="path-step" data-reveal-item style={`--delay: ${i * 100}ms`}>
                <span class="path-step-icon">
                  {step.icon === "compass" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>}
                  {step.icon === "lab" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 3v6"/><path d="M15 3v6"/><path d="M9 15v6"/><path d="M15 15v6"/><path d="M3 9h6"/><path d="M15 9h6"/><path d="M3 15h6"/><path d="15 15h6"/></svg>}
                  {step.icon === "cert" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>}
                  {step.icon === "rocket" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>}
                </span>
                <div class="path-step-content">
                  <span class="path-step-num">{String(i + 1).padStart(2, "0")}</span>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 04 The Space -->
    <section class="skills-section skills-space" id="ch-space" data-chapter>
      <div class="section-bg-icons" aria-hidden="true">
        <span class="bg-icon bg-icon-5"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4"><rect width="20" height="14" x="2" y="7" rx="2"/></svg></span>
      </div>
      <div class="container-page relative z-10 py-14 md:py-16">
        <div class="chapter-marker">
          <span class="chapter-num">04</span>
          <h2 class="chapter-title">The Space</h2>
        </div>
        <p class="chapter-tagline">TechHub is our community tech space—where the gap meets the bridge.</p>
        <div class="space-intro" data-reveal>
          <p class="space-intro-text">
            Many people lack access to training, devices, and mentors. TechHub changes that. It's a physical space in the community where learners get free access to computers, structured training, and real pathways to jobs. Here's how it addresses the barriers people face:
          </p>
        </div>
        <div class="space-solutions" data-reveal>
          <h3 class="space-solutions-title">How TechHub solves the gap</h3>
          <div class="space-solutions-grid">
            <div class="space-solution-item">
              <span class="space-solution-problem">Limited access</span>
              <span class="space-solution-arrow">→</span>
              <span class="space-solution-fix">Community-based lab—no travel to distant centres. Open 6 days a week.</span>
            </div>
            <div class="space-solution-item">
              <span class="space-solution-problem">Digital divide</span>
              <span class="space-solution-arrow">→</span>
              <span class="space-solution-fix">Free devices, internet, and digital literacy training for those who have none.</span>
            </div>
            <div class="space-solution-item">
              <span class="space-solution-problem">Skills mismatch</span>
              <span class="space-solution-arrow">→</span>
              <span class="space-solution-fix">Employer-aligned curriculum and industry labs so training leads to real jobs.</span>
            </div>
            <div class="space-solution-item">
              <span class="space-solution-problem">Cost barriers</span>
              <span class="space-solution-arrow">→</span>
              <span class="space-solution-fix">Scholarship seats and free programmes so everyone gets a fair chance.</span>
            </div>
          </div>
        </div>
        <div class="space-grid" data-reveal>
          <div class="space-content">
            <h3 class="space-features-heading">What happens inside</h3>
            {techHubFeatures.map((f, i) => (
              <div class="space-feature" data-reveal-item style={`--delay: ${i * 80}ms`}>
                <span class="space-feature-icon">
                  {f.icon === "screen" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="14" x="2" y="7" rx="2"/></svg>}
                  {f.icon === "lab" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 3v6"/><path d="M15 3v6"/><path d="M9 15v6"/><path d="M15 15v6"/></svg>}
                  {f.icon === "briefcase" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>}
                </span>
                <div>
                  <h3>{f.title}</h3>
                  <p>{f.description}</p>
                </div>
              </div>
            ))}
            <ul class="space-highlights">
              <li>Open 6 days a week with community trainers</li>
              <li>Scholarship seats for vulnerable learners</li>
              <li>Equipment and learning pods for hands-on practice</li>
            </ul>
          </div>
          <div class="space-media" data-reveal>
            <Image
              src={spaceImg}
              alt="TechHub"
              width={560}
              height={400}
              loading="lazy"
              widths={[360, 480, 560, 640]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 48vw, 560px"
              quality={80}
              class="space-img"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 05 The Proof -->
    <section class="skills-section skills-proof" id="ch-proof" data-chapter>
      <div class="section-bg-icons" aria-hidden="true">
        <span class="bg-icon bg-icon-6"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
      </div>
      <div class="container-page relative z-10 py-14 md:py-16">
        <div class="chapter-marker">
          <span class="chapter-num">05</span>
          <h2 class="chapter-title">The Proof</h2>
        </div>
        <p class="chapter-tagline">Real numbers. Real moments.</p>
        <div class="proof-stats" data-reveal>
          {outcomes.map((o, i) => (
            <div class="proof-stat" data-reveal-item data-count={o.value} style={`--delay: ${i * 60}ms`}>
              <span class="proof-value">{o.value}</span>
              <span class="proof-label">{o.label}</span>
            </div>
          ))}
        </div>
        <div class="outcomes-block">
          <h3 class="outcomes-title">Outcomes</h3>
          <p class="outcomes-intro">What learners achieve through our programmes.</p>
          <div class="outcomes-grid" data-reveal>
            {outcomeItems.map((item, i) => (
              <article class="outcome-card" data-reveal-item style={`--delay: ${i * 80}ms`}>
                <span class="outcome-icon">
                  {item.icon === "briefcase" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
                  {item.icon === "rocket" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>}
                  {item.icon === "screen" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="14" x="2" y="7" rx="2"/></svg>}
                  {item.icon === "star" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>}
                </span>
                <h4 class="outcome-card-title">{item.title}</h4>
                <p class="outcome-card-desc">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
        <div class="proof-gallery">
          {galleryItems.map((item, i) => (
            <figure class={`proof-gallery-item proof-gallery-${i + 1}`} data-reveal style={`--delay: ${i * 70}ms`}>
              <Image
                src={item.src}
                alt={item.alt}
                width={400}
                height={300}
                loading="lazy"
                widths={[200, 300, 400]}
                sizes="(max-width: 640px) 50vw, 33vw"
                quality={80}
                class="proof-img"
              />
              <figcaption>{item.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- 06 The Invite -->
    <section class="skills-section skills-invite" id="ch-invite" data-chapter>
      <div class="container-page relative z-10 py-14 md:py-16">
        <div class="chapter-marker">
          <span class="chapter-num">06</span>
          <h2 class="chapter-title">The Invite</h2>
        </div>
        <div class="invite-panel" data-reveal>
          <h2 class="invite-title">Help learners turn skills into livelihoods.</h2>
          <p class="invite-text">Your support keeps labs open, mentors available, placements accessible.</p>
          <div class="invite-ctas">
            <a href="/donate" class="skills-cta-primary">Donate for skills</a>
            <a href="/get-involved" class="skills-cta-secondary">Join the mentor team</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* Skill development: teal-based palette (SDG 4 Education / growth, trust, professional development) */
  .skills-narrative {
    --skills-accent: #0d9488;
    --skills-accent-dark: #0f766e;
    --skills-bg: #f0fdfa;
  }

  /* Hero */
  .skills-hero {
    position: relative;
    background: #f0fdfa;
    overflow: hidden;
  }

  .skills-hero-bg-icon {
    position: absolute;
    top: 10%;
    right: 5%;
    width: 12rem;
    height: 12rem;
    opacity: 0.06;
    color: var(--skills-accent);
  }

  .skills-hero-bg-icon svg {
    width: 100%;
    height: 100%;
  }

  .skills-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--brand-navy) 85%, black);
    background: white;
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .skills-hero-title {
    margin-top: 1rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--fg);
  }

  .skills-hero-lead {
    margin-top: 1rem;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 32rem;
  }

  .skills-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
