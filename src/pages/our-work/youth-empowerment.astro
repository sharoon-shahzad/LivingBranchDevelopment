---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
// Youth empowerment folder
import youthEmp1 from "../../images/programmes/youth/youth_empowerment/youth_emp.jpeg";
import youthEmp2 from "../../images/programmes/youth/youth_empowerment/youth_emp01.jpeg";
import youthEmp3 from "../../images/programmes/youth/youth_empowerment/gal06.jpeg";
// Youth conference folder
import youthConf1 from "../../images/programmes/youth/youth_conference/youth_hero_img.jpeg";
import youthConf2 from "../../images/programmes/youth/youth_conference/gal01.jpeg";
import youthConf3 from "../../images/programmes/youth/youth_conference/gal02.jpeg";
import youthConf6 from "../../images/programmes/youth/youth_conference/gal05.jpeg";

const barriers = [
  {
    title: "Unemployment & skills mismatch",
    description: "Youth face high unemployment; education often doesn't lead to jobs or market-ready skills.",
    livingBranch: "We offer job readiness training, digital skills, and entrepreneurship coaching—plus placement support and internships.",
    icon: "employment",
  },
  {
    title: "Mental health & anxiety",
    description: "Exam pressure, future uncertainty, and lack of support leave many youth stressed with nowhere to turn.",
    livingBranch: "Safe spaces, counselling, and peer support so young people can talk, heal, and build resilience.",
    icon: "wellbeing",
  },
  {
    title: "Lack of mentorship",
    description: "Without role models and guidance, youth struggle to navigate career choices and life decisions.",
    livingBranch: "Mentorship circles and one-to-one coaching connect youth with trusted adults who invest in their growth.",
    icon: "mentorship",
  },
  {
    title: "Limited opportunities",
    description: "Few scholarships, internships, and pathways for youth from under-resourced communities.",
    livingBranch: "Scholarship support, school retention, and links to apprenticeships—so talent gets a fair chance.",
    icon: "opportunity",
  },
];

const galleryItems = [
  { src: youthEmp1, alt: "Youth empowerment programme participants", label: "Youth empowerment" },
  { src: youthEmp2, alt: "Youth in leadership workshop", label: "Leadership circles" },
  { src: youthEmp3, alt: "Youth skills training session", label: "Skills & career prep" },
  { src: youthConf1, alt: "Youth conference gathering", label: "Youth conference" },
  { src: youthConf2, alt: "Youth mentorship session", label: "Mentorship" },
  { src: youthConf3, alt: "Youth fellowship and community", label: "Fellowship & community" },
];

const conferenceActivities = [
  { title: "Seminars & workshops", description: "Skill-building sessions on leadership, career readiness, and life skills." },
  { title: "Prayer meetings", description: "Spiritual gatherings to bless and encourage young people in their journey." },
  { title: "Fellowship & community", description: "Safe spaces for youth to connect, share, and grow together." },
  { title: "Mentorship & guidance", description: "One-to-one and group mentoring for direction and support." },
];

const stats = [
  { value: "1,800+", label: "Youth reached" },
  { value: "65", label: "Mentorship circles" },
  { value: "140", label: "Scholarships awarded" }
];

const pillars = [
  {
    title: "Leadership circles",
    description: "Build confidence, voice, and community leadership among young people."
  },
  {
    title: "Skills and career prep",
    description: "Offer job readiness, digital skills, and entrepreneurship coaching."
  },
  {
    title: "Wellbeing and protection",
    description: "Create safe spaces and guidance for healthy, resilient decision-making."
  }
];

const pathway = [
  {
    title: "Identify",
    text: "Connect with youth through schools and community partners."
  },
  {
    title: "Equip",
    text: "Deliver life skills, mentoring, and practical training."
  },
  {
    title: "Connect",
    text: "Link youth to scholarships, internships, and apprenticeships."
  },
  {
    title: "Sustain",
    text: "Follow up with coaching and family engagement."
  }
];

const outreach = [
  "Life skills and leadership workshops",
  "Mentorship matching and coaching",
  "Scholarship and school retention support",
  "Youth-led community action projects"
];
---

<Layout
  title="Youth Empowerment | Living Branch Development"
  description="Living Branch Development youth empowerment programmes build leadership, skills, and pathways to opportunity."
>
  <div class="youth-empowerment">
  <section class="youth-hero">
    <div class="youth-hero-bg-image" aria-hidden="true">
      <img src={youthConf1.src} alt="" width={1920} height={1080} loading="eager" decoding="async" />
    </div>
    <div class="youth-hero-bg-gradient" aria-hidden="true"></div>
    <div class="container-page relative z-10 grid gap-10 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p
          class="inline-flex items-center gap-2 rounded-full bg-white/75 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[color-mix(in_srgb,var(--brand-navy)_80%,black)] shadow-sm ring-1 ring-black/5"
        >
          Programme focus
        </p>
        <h1 class="mt-4 font-heading text-4xl font-semibold tracking-tight text-[var(--fg)] sm:text-5xl">
          Youth empowerment that turns potential into real opportunity.
        </h1>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-[var(--muted)] sm:text-lg">
          We build leadership, practical skills, and safe pathways so young people can thrive at school,
          at work, and in their communities.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="/donate"
            class="inline-flex items-center justify-center rounded-full bg-[var(--brand-navy)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[color-mix(in_srgb,var(--brand-navy)_85%,black)]"
          >
            Support youth
          </a>
          <a
            href="/get-involved"
            class="inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-white/80 px-6 py-3 text-sm font-semibold text-[var(--fg)] transition hover:border-[var(--brand-navy)] hover:bg-white"
          >
            Become a mentor
          </a>
        </div>
      </div>
      <div class="hero-stack">
        <div class="hero-image">
          <img
            src={youthEmp1.src}
            alt="Youth empowerment in action"
            width="520"
            height="420"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
        <div class="stat-stack">
          {stats.map((stat) => (
            <div class="stat-pill">
              <p class="text-xl font-semibold text-[var(--fg)]">{stat.value}</p>
              <p class="text-xs uppercase tracking-[0.2em] text-[var(--muted)]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What youth face + How LBD responds -->
  <section class="youth-barriers-surface" aria-labelledby="youth-barriers-heading">
    <div class="container-page py-14 md:py-16">
      <div class="youth-barriers-header">
        <p class="youth-barriers-eyebrow">What youth face today</p>
        <h2 id="youth-barriers-heading" class="youth-barriers-title">
          Barriers we break. Support we provide.
        </h2>
        <p class="youth-barriers-intro">
          Young people across Pakistan face real challenges. Here's how LBD responds to each.
        </p>
      </div>
      <div class="youth-barriers-grid">
        {barriers.map((b, i) => (
          <article class="youth-barrier-card" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
            <div class="youth-barrier-card-top">
              <span class="youth-barrier-icon" aria-hidden="true">
                {b.icon === "employment" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="14" x="2" y="7" rx="2" ry="2"/>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                  </svg>
                )}
                {b.icon === "wellbeing" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                  </svg>
                )}
                {b.icon === "mentorship" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                )}
                {b.icon === "opportunity" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2v4"/>
                    <path d="m3 3 2 2"/>
                    <path d="m21 3 2 2"/>
                    <path d="M18 12a6 6 0 0 1-6 6v0a6 6 0 0 1-6-6"/>
                    <path d="M12 22v-4"/>
                    <path d="m21 21-2-2"/>
                    <path d="m3 21-2-2"/>
                    <path d="M6 12a6 6 0 0 1 6-6v0a6 6 0 0 1 6 6"/>
                  </svg>
                )}
              </span>
              <div>
                <h3 class="youth-barrier-title">{b.title}</h3>
                <p class="youth-barrier-desc">{b.description}</p>
              </div>
            </div>
            <div class="youth-barrier-arrow" aria-hidden="true">
              <span class="youth-barrier-arrow-icon">→</span>
            </div>
            <div class="youth-barrier-response">
              <p class="youth-barrier-response-label">How LBD responds</p>
              <p class="youth-barrier-response-text">{b.livingBranch}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Image gallery: validates barriers section -->
  <section class="youth-gallery-surface" aria-labelledby="youth-gallery-heading">
    <div class="container-page py-14 md:py-16">
      <div class="youth-gallery-header">
        <p class="youth-barriers-eyebrow">See our work</p>
        <h2 id="youth-gallery-heading" class="youth-barriers-title">
          Youth thriving—in pictures.
        </h2>
        <p class="youth-barriers-intro">
          Real moments from our programmes: leadership circles, skills training, and youth leading change.
        </p>
      </div>
      <div class="youth-gallery">
        {galleryItems.map((item, i) => (
          <figure class={`youth-gallery-item youth-gallery-item-${i + 1}`} data-reveal style={`--reveal-delay: ${i * 120}ms`}>
            <div class="youth-gallery-img-wrap">
              <img
                src={item.src.src}
                alt={item.alt}
                width={400}
                height={300}
                loading="lazy"
                decoding="async"
                class="youth-gallery-img"
              />
            </div>
            <figcaption class="youth-gallery-caption">{item.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="pillars-header">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
        Service pillars
      </p>
      <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
        The support youth count on, every step.
      </h2>
    </div>
    <div class="pillars-grid">
      {pillars.map((pillar, index) => (
        <article class="pillar-card">
          <span class="pillar-index">0{index + 1}</span>
          <h3 class="mt-4 font-heading text-lg font-semibold text-[var(--fg)]">{pillar.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{pillar.description}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Youth Conferences -->
  <section class="youth-conferences-surface" aria-labelledby="youth-conferences-heading">
    <div class="container-page py-14 md:py-16">
      <div class="youth-conferences-header">
        <p class="youth-barriers-eyebrow">Youth conferences</p>
        <h2 id="youth-conferences-heading" class="youth-barriers-title">
          Seminars, prayer meetings, and spiritual blessing.
        </h2>
        <p class="youth-barriers-intro">
          Our youth conferences bring young people together for growth in mind, body, and spirit. Different seminars, prayer meetings to bless them spiritually, and fellowship gatherings are arranged to build confidence, belonging, and direction.
        </p>
      </div>
      <div class="conference-activities-grid">
        {conferenceActivities.map((activity, i) => (
          <article class="conference-activity-card" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <h3 class="conference-activity-title">{activity.title}</h3>
            <p class="conference-activity-desc">{activity.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="pathway-band">
    <div class="container-page py-12 sm:py-14">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          Growth pathway
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          From first contact to long-term growth.
        </h2>
      </div>
      <div class="pathway-grid">
        {pathway.map((step) => (
          <div class="pathway-card">
            <div class="pathway-dot" aria-hidden="true"></div>
            <h3 class="mt-4 font-heading text-lg font-semibold text-[var(--fg)]">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="grid gap-10 md:grid-cols-[1fr_1.1fr] md:items-center">
      <div class="outreach-image">
        <img
          src={youthEmp2.src}
          alt="Youth mentorship and community"
          width="520"
          height="420"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-contain"
        />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          Youth snapshot
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Building confidence, belonging, and direction.
        </h2>
        <ul class="mt-6 grid gap-3 text-sm text-[var(--muted)]">
          {outreach.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-[var(--brand-cyan)]" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="carousel-band">
    <div class="container-page py-12 sm:py-14">
      <div class="carousel-header">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
            Field moments
          </p>
          <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
            A closer look at youth leadership.
          </h2>
        </div>
        <div class="carousel-controls" aria-hidden="true">
          <a class="carousel-dot" href="#youth-slide-1"></a>
          <a class="carousel-dot" href="#youth-slide-2"></a>
          <a class="carousel-dot" href="#youth-slide-3"></a>
          <a class="carousel-dot" href="#youth-slide-4"></a>
        </div>
      </div>
      <div class="carousel-track" aria-label="Youth empowerment photo carousel">
        <article id="youth-slide-1" class="carousel-card">
          <img
            src={youthEmp1.src}
            alt="Youth empowerment"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
        <article id="youth-slide-2" class="carousel-card">
          <img
            src={youthEmp3.src}
            alt="Skills training"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
        <article id="youth-slide-3" class="carousel-card">
          <img
            src={youthConf2.src}
            alt="Youth conference"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
        <article id="youth-slide-4" class="carousel-card">
          <img
            src={youthConf6.src}
            alt="Youth leadership"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="cta-panel">
      <div>
        <h2 class="font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Keep opportunity open for every young person.
        </h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--muted)] sm:text-base">
          Your support funds mentors, scholarships, and safe spaces that help youth stay on track.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="/donate"
          class="inline-flex items-center justify-center rounded-full bg-[var(--brand-cyan)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[color-mix(in_srgb,var(--brand-cyan)_88%,black)]"
        >
          Donate for youth
        </a>
        <a
          href="/get-involved"
          class="inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-white px-6 py-3 text-sm font-semibold text-[var(--fg)] transition hover:border-[var(--brand-navy)]"
        >
          Explore partnerships
        </a>
      </div>
    </div>
  </section>
  </div>
</Layout>

<style>
  .youth-hero {
    position: relative;
    overflow: hidden;
  }

  .youth-hero-bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .youth-hero-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.2;
  }

  .youth-hero-bg-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(1100px 520px at 18% 12%, color-mix(in srgb, var(--brand-cyan) 18%, white), transparent 58%),
      radial-gradient(900px 520px at 88% 20%, color-mix(in srgb, var(--brand-cyan) 10%, white), transparent 65%),
      linear-gradient(180deg, rgba(255,255,255,0.88), #f2fbff 50%, #fff);
  }

  .hero-stack {
    display: grid;
    gap: 1.2rem;
  }

  .hero-image {
    border-radius: 28px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.8rem;
    box-shadow: 0 18px 40px rgba(12, 16, 34, 0.08);
  }

  .stat-stack {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  }

  .stat-pill {
    border-radius: 16px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 0.9rem 1rem;
    box-shadow: 0 10px 18px rgba(12, 16, 34, 0.06);
  }

  .pillars-header {
    max-width: 40rem;
  }

  .pillars-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .pillar-card {
    border-radius: 22px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.5rem;
    box-shadow: 0 12px 22px rgba(12, 16, 34, 0.08);
  }

  .pillar-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--brand-cyan) 15%, white);
    padding: 0.35rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--brand-navy) 80%, black);
  }

  .youth-conferences-surface {
    background: color-mix(in srgb, var(--brand-cyan) 8%, white);
  }

  .youth-conferences-header {
    max-width: 40rem;
    margin-bottom: 2rem;
  }

  .conference-activities-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .conference-activity-card {
    padding: 1.5rem;
    background: white;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--brand-cyan) 20%, white);
    box-shadow: 0 10px 28px rgba(0, 186, 242, 0.06);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  .conference-activity-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .conference-activity-title {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
  }

  .conference-activity-desc {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .pathway-band {
    background: #fff5f2;
  }

  .pathway-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .pathway-card {
    border-radius: 20px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.4rem 1.5rem;
    box-shadow: 0 10px 18px rgba(12, 16, 34, 0.06);
    position: relative;
  }

  .pathway-dot {
    height: 12px;
    width: 12px;
    border-radius: 999px;
    background: var(--brand-cyan);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--brand-cyan) 18%, transparent);
  }

  .outreach-image {
    border-radius: 24px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.5rem;
    box-shadow: 0 16px 32px rgba(12, 16, 34, 0.08);
  }

  /* Barriers + LBD response */
  .youth-barriers-surface {
    background: color-mix(in srgb, var(--brand-cyan) 8%, white);
  }

  .youth-barriers-header {
    max-width: 40rem;
