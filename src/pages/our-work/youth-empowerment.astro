---
import Layout from "../../layouts/Layout.astro";
import impact1 from "../../images/placeholders/impact-1.svg";
import impact2 from "../../images/placeholders/impact-2.svg";
import impact3 from "../../images/placeholders/impact-3.svg";
import impact4 from "../../images/placeholders/impact-4.svg";
import impact5 from "../../images/placeholders/impact-5.svg";

const stats = [
  { value: "1,800+", label: "Youth reached" },
  { value: "65", label: "Mentorship circles" },
  { value: "140", label: "Scholarships awarded" }
];

const pillars = [
  {
    title: "Leadership circles",
    description: "Build confidence, voice, and community leadership among young people."
  },
  {
    title: "Skills and career prep",
    description: "Offer job readiness, digital skills, and entrepreneurship coaching."
  },
  {
    title: "Wellbeing and protection",
    description: "Create safe spaces and guidance for healthy, resilient decision-making."
  }
];

const pathway = [
  {
    title: "Identify",
    text: "Connect with youth through schools and community partners."
  },
  {
    title: "Equip",
    text: "Deliver life skills, mentoring, and practical training."
  },
  {
    title: "Connect",
    text: "Link youth to scholarships, internships, and apprenticeships."
  },
  {
    title: "Sustain",
    text: "Follow up with coaching and family engagement."
  }
];

const outreach = [
  "Life skills and leadership workshops",
  "Mentorship matching and coaching",
  "Scholarship and school retention support",
  "Youth-led community action projects"
];
---

<Layout
  title="Youth Empowerment | Living Branch Development"
  description="Living Branch Development youth empowerment programmes build leadership, skills, and pathways to opportunity."
>
  <section class="youth-hero">
    <div class="container-page grid gap-10 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p
          class="inline-flex items-center gap-2 rounded-full bg-white/75 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[color-mix(in_srgb,var(--brand-navy)_80%,black)] shadow-sm ring-1 ring-black/5"
        >
          Programme focus
        </p>
        <h1 class="mt-4 font-heading text-4xl font-semibold tracking-tight text-[var(--fg)] sm:text-5xl">
          Youth empowerment that turns potential into real opportunity.
        </h1>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-[var(--muted)] sm:text-lg">
          We build leadership, practical skills, and safe pathways so young people can thrive at school,
          at work, and in their communities.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="/donate"
            class="inline-flex items-center justify-center rounded-full bg-[var(--brand-navy)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[color-mix(in_srgb,var(--brand-navy)_85%,black)]"
          >
            Support youth
          </a>
          <a
            href="/get-involved"
            class="inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-white/80 px-6 py-3 text-sm font-semibold text-[var(--fg)] transition hover:border-[var(--brand-navy)] hover:bg-white"
          >
            Become a mentor
          </a>
        </div>
      </div>
      <div class="hero-stack">
        <div class="hero-image">
          <img
            src={impact1.src}
            alt="Youth empowerment placeholder"
            width="520"
            height="420"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
        <div class="stat-stack">
          {stats.map((stat) => (
            <div class="stat-pill">
              <p class="text-xl font-semibold text-[var(--fg)]">{stat.value}</p>
              <p class="text-xs uppercase tracking-[0.2em] text-[var(--muted)]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="pillars-header">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
        Service pillars
      </p>
      <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
        The support youth count on, every step.
      </h2>
    </div>
    <div class="pillars-grid">
      {pillars.map((pillar, index) => (
        <article class="pillar-card">
          <span class="pillar-index">0{index + 1}</span>
          <h3 class="mt-4 font-heading text-lg font-semibold text-[var(--fg)]">{pillar.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{pillar.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="pathway-band">
    <div class="container-page py-12 sm:py-14">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          Growth pathway
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          From first contact to long-term growth.
        </h2>
      </div>
      <div class="pathway-grid">
        {pathway.map((step) => (
          <div class="pathway-card">
            <div class="pathway-dot" aria-hidden="true"></div>
            <h3 class="mt-4 font-heading text-lg font-semibold text-[var(--fg)]">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="grid gap-10 md:grid-cols-[1fr_1.1fr] md:items-center">
      <div class="outreach-image">
        <img
          src={impact2.src}
          alt="Mentorship placeholder"
          width="520"
          height="420"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-contain"
        />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
          Youth snapshot
        </p>
        <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Building confidence, belonging, and direction.
        </h2>
        <ul class="mt-6 grid gap-3 text-sm text-[var(--muted)]">
          {outreach.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-[var(--brand-cyan)]" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="carousel-band">
    <div class="container-page py-12 sm:py-14">
      <div class="carousel-header">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--brand-navy)_70%,var(--muted))]">
            Field moments
          </p>
          <h2 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
            A closer look at youth leadership.
          </h2>
        </div>
        <div class="carousel-controls" aria-hidden="true">
          <a class="carousel-dot" href="#youth-slide-1"></a>
          <a class="carousel-dot" href="#youth-slide-2"></a>
          <a class="carousel-dot" href="#youth-slide-3"></a>
          <a class="carousel-dot" href="#youth-slide-4"></a>
        </div>
      </div>
      <div class="carousel-track" aria-label="Youth empowerment photo carousel">
        <article id="youth-slide-1" class="carousel-card">
          <img
            src={impact3.src}
            alt="Youth workshop placeholder"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
        <article id="youth-slide-2" class="carousel-card">
          <img
            src={impact4.src}
            alt="Mentorship circle placeholder"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
        <article id="youth-slide-3" class="carousel-card">
          <img
            src={impact5.src}
            alt="Skills training placeholder"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
        <article id="youth-slide-4" class="carousel-card">
          <img
            src={impact1.src}
            alt="Youth leadership placeholder"
            width="520"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </article>
      </div>
    </div>
  </section>

  <section class="container-page py-12 sm:py-14">
    <div class="cta-panel">
      <div>
        <h2 class="font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl">
          Keep opportunity open for every young person.
        </h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-[var(--muted)] sm:text-base">
          Your support funds mentors, scholarships, and safe spaces that help youth stay on track.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="/donate"
          class="inline-flex items-center justify-center rounded-full bg-[var(--brand-cyan)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[color-mix(in_srgb,var(--brand-cyan)_88%,black)]"
        >
          Donate for youth
        </a>
        <a
          href="/get-involved"
          class="inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-white px-6 py-3 text-sm font-semibold text-[var(--fg)] transition hover:border-[var(--brand-navy)]"
        >
          Explore partnerships
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .youth-hero {
    background: #f2fbff;
  }

  .hero-stack {
    display: grid;
    gap: 1.2rem;
  }

  .hero-image {
    border-radius: 28px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.8rem;
    box-shadow: 0 18px 40px rgba(12, 16, 34, 0.08);
  }

  .stat-stack {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  }

  .stat-pill {
    border-radius: 16px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 0.9rem 1rem;
    box-shadow: 0 10px 18px rgba(12, 16, 34, 0.06);
  }

  .pillars-header {
    max-width: 40rem;
  }

  .pillars-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .pillar-card {
    border-radius: 22px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.5rem;
    box-shadow: 0 12px 22px rgba(12, 16, 34, 0.08);
  }

  .pillar-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--brand-cyan) 15%, white);
    padding: 0.35rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--brand-navy) 80%, black);
  }

  .pathway-band {
    background: #fff5f2;
  }

  .pathway-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .pathway-card {
    border-radius: 20px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.4rem 1.5rem;
    box-shadow: 0 10px 18px rgba(12, 16, 34, 0.06);
    position: relative;
  }

  .pathway-dot {
    height: 12px;
    width: 12px;
    border-radius: 999px;
    background: var(--brand-cyan);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--brand-cyan) 18%, transparent);
  }

  .outreach-image {
    border-radius: 24px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.5rem;
    box-shadow: 0 16px 32px rgba(12, 16, 34, 0.08);
  }

  .cta-panel {
    border-radius: 28px;
    border: 1px solid var(--border);
    background: #eef9f7;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .carousel-band {
    background: #ffffff;
  }

  .carousel-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .carousel-controls {
    display: flex;
    gap: 0.6rem;
  }

  .carousel-dot {
    height: 10px;
    width: 10px;
    border-radius: 999px;
    background: #d8dbe9;
  }

  .carousel-track {
    margin-top: 2rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .carousel-card {
    border-radius: 24px;
    border: 1px solid var(--border);
    background: #ffffff;
    padding: 1.2rem;
    box-shadow: 0 14px 26px rgba(12, 16, 34, 0.08);
  }
</style>
