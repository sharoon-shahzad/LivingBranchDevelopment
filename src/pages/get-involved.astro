---
import Layout from "../layouts/Layout.astro";

const programmeLinks = [
  {
    title: "Education",
    description: "Keep children learning with tutoring and family support.",
    href: "/our-work/education"
  },
  {
    title: "Youth Empowerment",
    description: "Mentorship, life skills, and opportunity pathways for young people.",
    href: "/our-work/youth-empowerment"
  },
  {
    title: "Skill Development",
    description: "Train youth and caregivers for steady, dignified livelihoods.",
    href: "/our-work/skill-development"
  },
  {
    title: "Women Empowerment",
    description: "Support safety, leadership, and economic resilience for women.",
    href: "/our-work/women-empowerment"
  }
];

const partnerReasons = [
  {
    title: "Community-led delivery",
    description: "We co-design every intervention with local leaders so support stays relevant and trusted."
  },
  {
    title: "Transparent reporting",
    description: "Clear updates, budgets, and milestones keep partners informed at every stage."
  },
  {
    title: "Measured outcomes",
    description: "We track progress with simple, human metrics that show real changes in daily life."
  }
];

const trustStats = [
  { value: "15k+", label: "People reached" },
  { value: "120+", label: "Communities" },
  { value: "260+", label: "Local volunteers" }
];

const faqItems = [
  {
    question: "How can I volunteer with Living Branch Development?",
    answer: "You can volunteer by signing up through our contact form or emailing us directly. We offer opportunities in mentoring, skills training, community outreach, and administrative support. We match your skills and availability with programmes that need you most."
  },
  {
    question: "What types of partnerships do you offer?",
    answer: "We partner with corporates for CSR initiatives, NGOs for programme collaboration, and individuals for funding and expertise. Partnerships can be project-based, long-term, or focused on specific programmes like education, youth empowerment, or disaster response."
  },
  {
    question: "How is my donation used?",
    answer: "Donations go directly to programme delivery—school supplies, skills training, counselling support, and community initiatives. We maintain transparent reporting and share impact updates with donors. Over 85% of funds go to programme activities."
  },
  {
    question: "Can I support a specific programme or community?",
    answer: "Yes. You can choose to support education, youth empowerment, women empowerment, skill development, counselling, or disaster response. We can also direct support to specific geographic areas when requested."
  },
  {
    question: "How do I become a mentor?",
    answer: "Mentors support youth and women through structured programmes. Apply via our contact form, and we will match you with a programme. Mentorship typically involves regular check-ins, guidance on skills and career, and ongoing support over 6–12 months."
  }
];
---

<Layout title="Get involved | Living Branch Development">
  <div class="get-involved-page">
  <section class="get-involved-hero">
    <div class="container-page grid gap-10 py-16 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div>
        <p class="get-involved-eyebrow">Get involved</p>
        <h1 class="get-involved-title">
          Your time and partnership can rewrite a family’s future.
        </h1>
        <p class="get-involved-subtitle">
          Every programme is built with communities, not just for them. Join us with resources, expertise, or
          funding that keeps essential support consistent.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="/get-involved#partner"
            class="btn-primary"
          >
            Partner with us
          </a>
          <a
            href="/donate"
            class="btn-accent"
          >
            Donate now
          </a>
        </div>
      </div>

      <div class="hero-card">
        <div class="hero-icon-grid">
          <div class="hero-icon">
            <div class="hero-icon-badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M8 10.5 6 8.6A3 3 0 1 1 10.2 4l1.8 2 1.9-2A3 3 0 1 1 18 8.6l-2 1.9v3.8a3.5 3.5 0 0 1-7 0v-3.8Z"
                />
              </svg>
            </div>
            <h3 class="font-heading text-sm font-semibold text-[var(--fg)]">Donate</h3>
            <p class="text-xs text-[var(--muted)]">Fund essentials that families rely on.</p>
          </div>
          <div class="hero-icon">
            <div class="hero-icon-badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M7.5 12a3.5 3.5 0 0 1 6.7-1.4l3.3 3.3a2.5 2.5 0 0 1-3.6 3.5l-3.1-3.2-2.1 2.1a2.5 2.5 0 0 1-3.6-3.5Z"
                />
              </svg>
            </div>
            <h3 class="font-heading text-sm font-semibold text-[var(--fg)]">Partner</h3>
            <p class="text-xs text-[var(--muted)]">Co-create solutions and scale impact.</p>
          </div>
          <div class="hero-icon">
            <div class="hero-icon-badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M12 4a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm-6.5 15a4.5 4.5 0 0 1 9 0v1H5.5v-1Zm10 0a4.5 4.5 0 0 1 9 0v1h-9v-1Z"
                />
              </svg>
            </div>
            <h3 class="font-heading text-sm font-semibold text-[var(--fg)]">Volunteer</h3>
            <p class="text-xs text-[var(--muted)]">Give your time and skills locally.</p>
          </div>
          <div class="hero-icon">
            <div class="hero-icon-badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
                <path
                  fill="currentColor"
                  d="M4 7.5A3.5 3.5 0 0 1 7.5 4h9A3.5 3.5 0 0 1 20 7.5v9a3.5 3.5 0 0 1-3.5 3.5h-9A3.5 3.5 0 0 1 4 16.5v-9Z"
                />
                <path fill="#fff" d="M8 9h8v2H8V9Zm0 4h5v2H8v-2Z" />
              </svg>
            </div>
            <h3 class="font-heading text-sm font-semibold text-[var(--fg)]">Mentor</h3>
            <p class="text-xs text-[var(--muted)]">Guide learners into new careers.</p>
          </div>
        </div>
        <div class="hero-note">
          <p class="hero-note-label">Where you come in</p>
          <p class="hero-note-text">
            Pick a path below and we will connect you to the right programme team.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="programme-section">
    <div class="container-page py-12 sm:py-14">
    <div class="programme-header">
      <p class="section-eyebrow">Support a programme</p>
      <h2 class="section-title">
        Choose where you want your impact to begin.
      </h2>
      <p class="section-intro">
        Each programme meets a different community need. Pick a focus area and we will guide you to the right team.
      </p>
    </div>
    <div class="programme-grid">
      {programmeLinks.map((programme) => (
        <a href={programme.href} class="programme-card">
          <div>
            <h3 class="font-heading text-lg font-semibold text-[var(--fg)]">{programme.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{programme.description}</p>
          </div>
          <span class="programme-link">Explore programme</span>
        </a>
      ))}
    </div>
    </div>
  </section>

  <section class="partner-band" id="partner">
    <div class="container-page py-12 sm:py-14">
      <div class="partner-header">
        <p class="section-eyebrow">Why partner with us</p>
        <h2 class="section-title">
          Trusted collaboration that turns support into outcomes.
        </h2>
        <p class="section-intro">
          We build long-term partnerships rooted in local insight, shared accountability, and measurable impact.
        </p>
      </div>
      <div class="partner-grid">
        {partnerReasons.map((reason, index) => (
          <div class="partner-card">
            <span class="partner-index">0{index + 1}</span>
            <h3 class="mt-4 font-heading text-lg font-semibold text-[var(--fg)]">{reason.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--muted)]">{reason.description}</p>
          </div>
        ))}
      </div>
      <div class="partner-cta">
        <div>
          <h3 class="partner-cta-title">Let’s build a partnership plan.</h3>
          <p class="partner-cta-text">
            We will align your goals with the programmes that need you most.
          </p>
        </div>
        <a
          href="/contact"
          class="btn-primary btn-cta"
        >
          Start a partnership
        </a>
      </div>
    </div>
  </section>

  <section class="trust-band">
    <div class="container-page py-12 sm:py-14">
      <div class="trust-grid">
        <div>
          <p class="section-eyebrow">Trust & impact</p>
          <h2 class="section-title">
            Built with communities, measured with care.
          </h2>
          <p class="section-intro">
            Partners stay with us because they see consistent delivery, honest reporting, and outcomes that last.
          </p>
          <div class="mt-6 grid gap-3 sm:grid-cols-3">
            {trustStats.map((stat) => (
              <div class="trust-stat">
                <p class="text-xl font-semibold text-[var(--fg)]">{stat.value}</p>
                <p class="mt-1 text-xs uppercase tracking-[0.2em] text-[var(--muted)]">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="trust-quote">
          <p class="text-sm uppercase tracking-[0.2em] text-[var(--muted)]">Partner note</p>
          <p class="mt-4 text-lg leading-relaxed text-[var(--fg)]">
            “Living Branch Development makes it easy to align our CSR goals with real community needs. The
            collaboration feels honest and grounded.”
          </p>
          <p class="mt-4 text-sm font-semibold text-[color-mix(in_srgb,var(--brand-navy)_75%,black)]">
            Corner Stone Community Development, Pakistan
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-band" id="faq" aria-labelledby="faq-heading">
    <div class="container-page py-14 md:py-16">
      <div class="faq-header">
        <p class="faq-eyebrow">Frequently asked questions</p>
        <h2 id="faq-heading" class="faq-title">
          Common questions about getting involved.
        </h2>
        <p class="faq-intro">
          Find quick answers below. For more details, reach out through our contact form.
        </p>
      </div>
      <div class="faq-list">
        {faqItems.map((item, i) => (
          <div class="faq-item" data-faq-item>
            <button
              type="button"
              class="faq-trigger"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
              id={`faq-question-${i}`}
              data-faq-trigger
            >
              <span class="faq-question">{item.question}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </span>
            </button>
            <div
              class="faq-answer-wrap"
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-question-${i}`}
              hidden
            >
              <div class="faq-answer">
                <p>{item.answer}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  </div>
</Layout>

<style>
  /* ─── Color tokens: navy blue & dark orange ─── */
  .get-involved-page {
    --gi-navy: #0c1022;
    --gi-navy-mid: #1e293b;
    --gi-navy-light: #334155;
    --gi-navy-muted: #475569;
    --gi-orange: #c2410c;
    --gi-orange-bright: #ea580c;
    --gi-orange-light: #f97316;
    --gi-orange-tint: rgba(194, 65, 12, 0.08);
    --gi-orange-tint-strong: rgba(194, 65, 12, 0.15);
    --gi-navy-tint: rgba(12, 16, 34, 0.06);
    --gi-navy-tint-strong: rgba(12, 16, 34, 0.12);
  }

  /* Hero */
  .get-involved-hero {
    background: linear-gradient(165deg, #faf8f5 0%, #f5f0eb 50%, #fef7ed 100%);
  }

  .get-involved-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--gi-orange);
    background: var(--gi-orange-tint);
    border: 1px solid rgba(194, 65, 12, 0.2);
  }

  .get-involved-title {
    margin-top: 1rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--gi-navy);
  }

  .get-involved-subtitle {
    margin-top: 1rem;
    max-width: 36rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--gi-navy-muted);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    background: var(--gi-navy);
    border: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-primary:hover {
    background: var(--gi-navy-mid);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(12, 16, 34, 0.25);
  }

  .btn-accent {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    background: var(--gi-orange);
    border: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-accent:hover {
    background: var(--gi-orange-bright);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(194, 65, 12, 0.35);
  }

  .btn-cta {
    flex-shrink: 0;
  }

  .hero-card {
    border-radius: 28px;
    border: 1px solid rgba(12, 16, 34, 0.08);
    background: #fff;
    padding: 1.8rem;
    box-shadow: 0 18px 40px rgba(12, 16, 34, 0.06);
    display: grid;
    gap: 1.4rem;
  }

  .hero-icon-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .hero-icon {
    border-radius: 18px;
    border: 1px solid rgba(12, 16, 34, 0.06);
    background: var(--gi-orange-tint);
    padding: 1rem;
    display: grid;
    gap: 0.4rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .hero-icon:hover {
    border-color: rgba(194, 65, 12, 0.2);
    background: var(--gi-orange-tint-strong);
  }

  .hero-icon-badge {
    height: 40px;
    width: 40px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--gi-orange);
    color: #fff;
  }

  .hero-icon h3 {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gi-navy);
  }

  .hero-icon p {
    font-size: 0.75rem;
    color: var(--gi-navy-muted);
  }

  .hero-note {
    border-radius: 18px;
    border: 1px dashed rgba(194, 65, 12, 0.25);
    background: var(--gi-orange-tint);
    padding: 1rem 1.1rem;
  }

  .hero-note-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gi-navy-muted);
  }

  .hero-note-text {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--gi-navy);
  }

  /* Programme section */
  .programme-section {
    background: #fff;
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gi-orange);
  }

  .section-title {
    margin-top: 0.75rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 600;
    color: var(--gi-navy);
  }

  .section-intro {
    margin-top: 0.75rem;
    max-width: 42rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--gi-navy-muted);
  }

  .programme-header {
    max-width: 44rem;
  }

  .programme-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .programme-card {
    border-radius: 22px;
    border: 1px solid rgba(12, 16, 34, 0.08);
    background: #fff;
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    justify-content: space-between;
    box-shadow: 0 8px 24px rgba(12, 16, 34, 0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .programme-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 32px rgba(12, 16, 34, 0.1);
    border-color: rgba(194, 65, 12, 0.25);
  }

  .programme-card h3 {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--gi-navy);
  }

  .programme-card p {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--gi-navy-muted);
  }

  .programme-link {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gi-orange);
  }

  /* Partner band */
  .partner-band {
    background: linear-gradient(180deg, #fef7ed 0%, #faf8f5 100%);
  }

  .partner-header {
    max-width: 44rem;
  }

  .partner-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .partner-card {
    border-radius: 22px;
    border: 1px solid rgba(12, 16, 34, 0.06);
    background: #fff;
    padding: 1.4rem;
    box-shadow: 0 8px 24px rgba(12, 16, 34, 0.04);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .partner-card:hover {
    border-color: rgba(194, 65, 12, 0.2);
    box-shadow: 0 12px 28px rgba(12, 16, 34, 0.08);
  }

  .partner-card h3 {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--gi-navy);
  }

  .partner-card p {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--gi-navy-muted);
  }

  .partner-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    padding: 0.35rem 0.7rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: var(--gi-orange-tint-strong);
    color: var(--gi-orange);
  }

  .partner-cta {
    margin-top: 2rem;
    border-radius: 22px;
    border: 1px solid rgba(194, 65, 12, 0.2);
    background: #fff;
    padding: 1.2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 8px 24px rgba(12, 16, 34, 0.06);
  }

  .partner-cta-title {
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gi-navy);
  }

  .partner-cta-text {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--gi-navy-muted);
  }

  /* Trust band */
  .trust-band {
    background: linear-gradient(180deg, #f8f9fc 0%, #fff 100%);
  }

  .trust-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .trust-stat {
    border-radius: 16px;
    border: 1px solid rgba(12, 16, 34, 0.06);
    background: #fff;
    padding: 0.9rem 1rem;
    box-shadow: 0 6px 16px rgba(12, 16, 34, 0.04);
  }

  .trust-stat p:first-child {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gi-navy);
  }

  .trust-stat p:last-child {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gi-navy-muted);
  }

  .trust-quote {
    border-radius: 24px;
    border: 1px solid rgba(12, 16, 34, 0.06);
    background: #fff;
    padding: 1.6rem;
    box-shadow: 0 12px 28px rgba(12, 16, 34, 0.06);
  }

  .trust-quote-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gi-orange);
  }

  .trust-quote-text {
    margin-top: 1rem;
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--gi-navy);
  }

  .trust-quote-author {
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gi-navy-mid);
  }

  @media (min-width: 768px) {
    .partner-cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (min-width: 1024px) {
    .trust-grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  @media (min-width: 1024px) {
    .hero-icon-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* FAQ section */
  .faq-band {
    background: linear-gradient(180deg, #faf8f5 0%, #fff 100%);
  }

  .faq-header {
    max-width: 36rem;
    margin-bottom: 2.5rem;
  }

  .faq-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gi-orange);
  }

  .faq-title {
    margin-top: 0.5rem;
    font-family: Poppins, Inter, system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--gi-navy);
  }

  .faq-intro {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--gi-navy-muted);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 42rem;
  }

  .faq-item {
    border-radius: 16px;
    border: 1px solid rgba(12, 16, 34, 0.08);
    background: #fff;
    box-shadow: 0 2px 8px rgba(12, 16, 34, 0.04);
    overflow: hidden;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .faq-item:hover {
    border-color: rgba(194, 65, 12, 0.2);
    box-shadow: 0 4px 16px rgba(12, 16, 34, 0.08);
  }

  .faq-item[data-open] {
    border-color: rgba(194, 65, 12, 0.35);
    box-shadow: 0 8px 24px rgba(12, 16, 34, 0.1);
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    text-align: left;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.25s ease;
  }

  .faq-trigger:hover {
    background: var(--gi-orange-tint);
  }

  .faq-trigger:focus-visible {
    outline: 2px solid var(--gi-orange);
    outline-offset: 2px;
  }

  .faq-question {
    font-size: 1rem;
    font-weight: 600;
    color: var(--gi-navy);
    line-height: 1.4;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--gi-navy-tint);
    color: var(--gi-navy);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), background 0.25s ease, color 0.25s ease;
  }

  .faq-item[data-open] .faq-icon {
    transform: rotate(180deg);
    background: var(--gi-orange-tint-strong);
    color: var(--gi-orange);
  }

  .faq-answer-wrap {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item[data-open] .faq-answer-wrap {
    max-height: 500px;
  }

  .faq-answer {
    padding: 0 1.5rem 1.25rem;
    border-top: 1px solid rgba(12, 16, 34, 0.06);
  }

  .faq-answer p {
    padding-top: 1rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--gi-navy-muted);
  }

  .faq-item[data-open] .faq-answer {
    border-top-color: rgba(194, 65, 12, 0.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-answer-wrap {
      transition: none;
    }
    .faq-icon {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll("[data-faq-trigger]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const item = btn.closest("[data-faq-item]");
      const isOpen = item?.hasAttribute("data-open");
      const answerWrap = item?.querySelector(".faq-answer-wrap");
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (isOpen) {
        item.removeAttribute("data-open");
        btn.setAttribute("aria-expanded", "false");
        if (answerWrap) {
          answerWrap.hidden = true;
          if (prefersReduced) answerWrap.style.maxHeight = "";
        }
      } else {
        item?.setAttribute("data-open", "");
        btn.setAttribute("aria-expanded", "true");
        if (answerWrap) {
          answerWrap.hidden = false;
          if (prefersReduced) answerWrap.style.maxHeight = "none";
        }
      }
    });
  });
</script>

