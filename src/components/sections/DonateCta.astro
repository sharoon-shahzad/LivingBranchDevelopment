---
---

<section
  class="donate-cta-surface border-y border-[color-mix(in_srgb,white_18%,var(--border))] bg-linear-to-br from-blue-950 via-blue-900 to-cyan-900"
  aria-labelledby="donate-cta-heading"
>
  <div class="container-page grid gap-10 py-14 md:grid-cols-2 md:items-center lg:gap-14">
    <div>
      <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-white shadow-sm ring-1 ring-white/15 backdrop-blur">
        Support a cause
      </p>

      <h2
        id="donate-cta-heading"
        class="mt-4 font-heading text-3xl font-semibold tracking-tight text-white sm:text-4xl"
      >
        Your gift grows
        <span class="block text-cyan-100">stronger branches.</span>
      </h2>

      <p class="mt-4 max-w-xl text-sm leading-relaxed text-cyan-100/90 sm:text-base">
        Every contribution helps strengthen education, health care, and livelihood programmes for children,
        families, and communities that are most at risk of being left behind.
      </p>

      <p class="mt-2 max-w-xl text-sm leading-relaxed text-cyan-100/85 sm:text-base">
        Choose the amount and frequency that works for you. We&rsquo;ll make sure it reaches where it is needed
        most.
      </p>
    </div>

    <div class="rounded-3xl border border-white/15 bg-white/95 p-5 shadow-xl sm:p-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--muted)]">
            Bank transfer (no gateway)
          </p>
          <p class="mt-2 font-heading text-xl font-semibold text-[var(--fg)] sm:text-2xl">
            Send support directly to our bank.
          </p>
        </div>
        <span
          class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[color-mix(in_srgb,var(--brand-cyan)_16%,white)] text-[var(--brand-cyan)] ring-1 ring-[color-mix(in_srgb,var(--brand-cyan)_22%,white)]"
          aria-hidden="true"
        >
          <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 10h18" />
            <path d="M5 10V7l7-4 7 4v3" />
            <path d="M6 10v9" />
            <path d="M10 10v9" />
            <path d="M14 10v9" />
            <path d="M18 10v9" />
            <path d="M4 19h16" />
          </svg>
        </span>
      </div>

      <div class="mt-5 grid gap-3">
        <div class="rounded-2xl border border-[var(--border)] bg-white p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">How it works</p>
          <ol class="mt-3 grid gap-2 text-sm text-[color-mix(in_srgb,var(--brand-navy)_80%,black)]">
            <li class="flex gap-2">
              <span class="mt-1 h-2 w-2 rounded-full bg-[var(--brand-cyan)]" aria-hidden="true"></span>
              <span>Open your banking app and choose <strong>Bank Transfer</strong>.</span>
            </li>
            <li class="flex gap-2">
              <span class="mt-1 h-2 w-2 rounded-full bg-[var(--brand-cyan)]" aria-hidden="true"></span>
              <span>Copy the account details from our Bank Details page.</span>
            </li>
            <li class="flex gap-2">
              <span class="mt-1 h-2 w-2 rounded-full bg-[var(--brand-cyan)]" aria-hidden="true"></span>
              <span>Send and keep the reference for your records.</span>
            </li>
          </ol>
        </div>

        <div class="flex justify-center">
          <a
            href="/donate/bank-details"
            class="inline-flex items-center justify-center rounded-full bg-linear-to-r from-orange-500 to-red-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:from-orange-600 hover:to-red-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-300/60"
          >
            View bank details
          </a>
        </div>

        <p class="text-[0.75rem] text-[var(--muted)]">
          Tip: This works great from desktop too—open the Bank Details page on your phone and copy the account number safely.
        </p>
      </div>
    </div>
  </div>
</section>

