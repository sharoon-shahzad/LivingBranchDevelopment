---
import { Image } from "astro:assets";
import agapeTrust from "../../images/partners/AGAPE TRUST.jpeg";
import assembliesOfGod from "../../images/partners/AssembliesofGod.jpeg";
import award from "../../images/partners/Award.jpeg";
import cornerstone from "../../images/partners/cornerstone.jpeg";
import familiesSetFree from "../../images/partners/FamiliesSetFree.jpeg";
import livingBranchChurch from "../../images/partners/LBC(LivingBranchChurch).jpeg";
import peaceAmbassadorSociety from "../../images/partners/PeaceAmbassadorSociety.jpeg";
import pakistanPartnershipInitiative from "../../images/partners/ppi(PakistanPartnership initiative).jpeg";
import resilientWomenNetwork from "../../images/partners/ResilientWomenNetwork.jpeg";

const partners = [
  { name: "Agape Trust", image: agapeTrust },
  { name: "Assemblies of God", image: assembliesOfGod },
  { name: "Award", image: award },
  { name: "Cornerstone", image: cornerstone },
  { name: "Families Set Free", image: familiesSetFree },
  { name: "Living Branch Church", image: livingBranchChurch },
  { name: "Peace Ambassador Society", image: peaceAmbassadorSociety },
  { name: "Pakistan Partnership Initiative", image: pakistanPartnershipInitiative },
  { name: "Resilient Women Network", image: resilientWomenNetwork }
];
---

<section class="partners-surface" aria-labelledby="partners-heading">
  <div class="container-page py-14 sm:py-16">
    <div class="text-center">
      <p class="eyebrow-brush inline-block">Our partners in change</p>
      <h2
        id="partners-heading"
        class="mt-3 font-heading text-2xl font-semibold tracking-tight text-[var(--fg)] sm:text-3xl"
      >
        Standing together for community impact.
      </h2>
      <p class="mt-3 max-w-2xl mx-auto text-sm leading-relaxed text-[var(--muted)] sm:text-base">
        We are grateful for the organisations and individuals who walk with us. Their trust and collaboration
        help Living Branch Development reach more children, families, and neighbourhoods every year.
      </p>
    </div>

    <div id="partners-grid" class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {partners.map((partner, idx) => (
        <article
          class:list={[
            "group h-28 items-center justify-center rounded-3xl border border-[var(--border)] bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:border-[color-mix(in_srgb,var(--brand-cyan)_50%,var(--border))] hover:shadow-lg",
            idx >= 6 ? "partner-extra hidden sm:flex" : "flex",
          ]}
          style={idx >= 6 ? `--reveal-delay:${(idx - 6) * 110}ms` : undefined}
        >
          <div class="flex flex-col items-center gap-3">
            <div class="flex h-14 w-full items-center justify-center sm:h-16">
              <Image
                src={partner.image}
                alt={partner.name}
                width={240}
                height={120}
                loading="lazy"
                class="max-h-14 w-auto object-contain sm:max-h-16"
              />
            </div>
            <p class="max-w-[11rem] text-center text-[0.8rem] font-medium tracking-tight text-[color-mix(in_srgb,var(--brand-navy)_65%,black)] sm:text-[0.85rem]">
              {partner.name}
            </p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-6 flex justify-center sm:hidden">
      <button
        type="button"
        class="partners-more-btn"
        data-partners-toggle
        aria-expanded="false"
        aria-controls="partners-grid"
      >
        Read more
      </button>
    </div>
  </div>
</section>

<script>
  if (typeof window !== "undefined") {
    const section = document.querySelector(".partners-surface");
    const toggle = document.querySelector("[data-partners-toggle]");
    const extras = document.querySelectorAll(".partner-extra");

    if (section && toggle && extras.length) {
      const prefersReduced =
        window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const updateLabel = (expanded) => {
        toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
        toggle.textContent = expanded ? "Show less" : "Read more";
      };

      updateLabel(false);

      toggle.addEventListener("click", () => {
        const expanded = section.getAttribute("data-expanded") === "true";
        section.setAttribute("data-expanded", expanded ? "false" : "true");
        updateLabel(!expanded);

        if (!expanded && prefersReduced) {
          // Ensure content is visible immediately without animation.
          extras.forEach((el) => el.classList.add("no-motion"));
        }
      });
    } else if (toggle) {
      // No extras; hide button.
      toggle.setAttribute("hidden", "true");
    }
  }
</script>

<style>
  .partners-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--brand-cyan) 28%, var(--border));
    background: color-mix(in srgb, var(--brand-cyan) 10%, white);
    padding: 0.6rem 1.05rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--brand-navy) 85%, black);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .partners-more-btn:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--brand-cyan) 45%, var(--border));
    box-shadow: 0 10px 18px rgba(12, 16, 34, 0.08);
  }

  .partners-surface[data-expanded="true"] .partner-extra {
    display: flex;
    animation: partnerReveal 420ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: var(--reveal-delay, 0ms);
  }

  .partners-surface .partner-extra.no-motion {
    animation: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .partners-surface[data-expanded="true"] .partner-extra {
      animation: none;
    }
  }

  @keyframes partnerReveal {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

